# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ─── Solana RPC (QuickNode) ────────────────────────────────────────────────────
# HTTP endpoint — blockhash fetch, tx send, confirmation polling, SOL price
QUICKNODE_RPC=https://your-endpoint.quiknode.pro/YOUR_KEY/

# WebSocket endpoint — real-time tx confirmation (fallback to HTTP polling if omitted)
QUICKNODE_WSS=wss://your-endpoint.quiknode.pro/YOUR_KEY/

# ─── Wallets ───────────────────────────────────────────────────────────────────
# All SOL payments are sent to this address
AGENCY_WALLET=YourSolanaPublicKeyHere

# Connecting this wallet unlocks the /admin panel (can be same as AGENCY_WALLET)
ADMIN_WALLET=YourSolanaPublicKeyHere

# ─── Discord Bot ───────────────────────────────────────────────────────────────
# New order announcements + status update notifications
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_SERVER_ID=your-server-id
DISCORD_CHANNEL_ID=your-announcements-channel-id
# Role ID to @mention on new orders (leave blank to disable role ping)
DISCORD_NOTIFY_ROLE=your-role-id
