<!-- Cart overlay -->
<div id="cart-overlay" onclick="toggleCart()"></div>

<!-- Cart panel -->
<div id="cart-panel">
  <div class="p-5 border-b border-dark-border flex items-center justify-between">
    <div>
      <h2 class="font-display font-bold text-lg text-white">YOUR ORDER</h2>
      <p class="font-mono text-xs text-slate-500 mt-0.5">REVIEW & CHECKOUT</p>
    </div>
    <button onclick="toggleCart()" class="text-slate-400 hover:text-white text-xl leading-none p-1">✕</button>
  </div>
  <div id="cart-items" class="p-5 flex flex-col gap-3 min-h-32"></div>
  <div class="p-5 border-t border-dark-border">
    <div class="flex justify-between items-center mb-2">
      <span class="font-mono text-xs text-slate-400">TOTAL (USD)</span>
      <span class="font-display font-bold text-xl text-brand-bright" id="cart-total">$0</span>
    </div>
    <div class="flex justify-between items-center mb-5">
      <span class="font-mono text-xs text-slate-500">≈ SOL</span>
      <span class="font-mono text-sm text-brand-bright" id="cart-total-sol">—</span>
    </div>
    <% if (locals.walletAddress) { %>
      <a href="/cart" class="block w-full text-center font-mono text-xs px-6 py-3 rounded-sm text-white transition-all hover:opacity-90" style="background:#1a6fff;letter-spacing:0.05em">CHECKOUT →</a>
    <% } else { %>
      <button onclick="closeCart();openConnectModal();" class="w-full font-mono text-xs px-6 py-3 rounded-sm text-white transition-all hover:opacity-90" style="background:#1a6fff">CONNECT WALLET TO ORDER</button>
    <% } %>
    <p class="font-mono text-xs text-slate-600 text-center mt-3">PAYMENT VIA SOL</p>
  </div>
</div>

<!-- Connect modal -->
<div id="conn-modal">
  <div class="relative w-full max-w-md mx-4 rounded-md p-8 sm:p-10" style="background:#080d1a;border:1px solid #0f1e3a">
    <button onclick="closeConnectModal()" class="absolute top-4 right-4 text-slate-500 hover:text-white text-lg leading-none">✕</button>
    <div class="flex items-center gap-3 mb-6">
      <img src="/images/logo.jpg" alt="logo" class="logo-img w-8 h-8 object-cover rounded-sm" />
      <span class="font-display font-bold text-lg text-white">BLUE <span class="text-brand-core">BRICK</span></span>
    </div>
    <h3 class="font-display font-bold text-2xl text-white mb-2">Connect Wallet</h3>
    <p class="text-slate-400 text-sm mb-7">Connect your Solana wallet to access the dashboard and place orders.</p>
    <div class="flex flex-col gap-3" id="wallet-opts">
      <button onclick="connectPhantom()" class="flex items-center gap-4 p-4 rounded-sm border border-dark-border hover:border-purple-500 hover:bg-purple-900/10 transition-all text-left">
        <span class="text-2xl">👻</span>
        <div><div class="font-display font-semibold text-white">Phantom</div><div class="font-mono text-xs text-slate-500 mt-0.5">MOST POPULAR</div></div>
      </button>
      <button onclick="connectBackpack()" class="flex items-center gap-4 p-4 rounded-sm border border-dark-border hover:border-blue-500 hover:bg-blue-900/10 transition-all text-left">
        <span class="text-2xl">🎒</span>
        <div><div class="font-display font-semibold text-white">Backpack</div><div class="font-mono text-xs text-slate-500 mt-0.5">xNFT WALLET</div></div>
      </button>
      <button onclick="connectSolflare()" class="flex items-center gap-4 p-4 rounded-sm border border-dark-border hover:border-orange-500 hover:bg-orange-900/10 transition-all text-left">
        <span class="text-2xl">🔆</span>
        <div><div class="font-display font-semibold text-white">Solflare</div><div class="font-mono text-xs text-slate-500 mt-0.5">LEDGER SUPPORT</div></div>
      </button>
    </div>
    <div id="wallet-connecting" class="hidden text-center py-8">
      <div class="font-mono text-sm text-slate-400 mb-4">CONNECTING...</div>
      <div class="w-8 h-8 border-2 border-brand-core border-t-transparent rounded-full animate-spin mx-auto"></div>
    </div>
    <div id="wallet-error" class="hidden mt-4 p-3 rounded-sm font-mono text-xs text-red-400 border border-red-900 bg-red-950/30"></div>
    <p class="font-mono text-xs text-slate-600 text-center mt-6">Powered by QuickNode RPC · Solana Mainnet</p>
  </div>
</div>

<!-- Toast -->
<div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[400] font-mono text-xs px-5 py-3 rounded-sm opacity-0 pointer-events-none transition-all duration-300 border border-dark-border whitespace-nowrap" style="background:#080d1a"></div>

<!-- Footer -->
<footer class="layer border-t border-dark-border mt-24 sm:mt-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div class="sm:col-span-2 md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo.jpg" alt="Blue Brick" class="logo-img w-10 h-10 object-cover rounded-sm" />
          <span class="font-display font-bold text-xl text-white">BLUE <span class="text-brand-core">BRICK</span></span>
        </div>
        <p class="text-slate-400 text-sm max-w-xs leading-relaxed">Building the infrastructure of the Solana ecosystem. From tokens to dApps, we architect your on-chain presence.</p>
      </div>
      <div>
        <h4 class="font-mono text-xs tracking-widest text-slate-500 mb-4">CONNECT</h4>
        <ul class="flex flex-col gap-2 text-sm text-slate-400">
          <li><a href="https://x.com/bluebrickonsol" target="_blank" rel="noopener" class="hover:text-white transition-colors font-mono text-xs tracking-wide">X</a></li>
          <li><a href="https://discord.com/invite/k7xbBrrJWF" target="_blank" rel="noopener" class="hover:text-white transition-colors font-mono text-xs tracking-wide">Discord</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-dark-border mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="font-mono text-xs text-slate-600">© 2026 BLUE BRICK. ALL RIGHTS RESERVED.</p>
      <p class="font-mono text-xs text-brand-core">BUILT ON SOLANA ◎</p>
    </div>
  </div>
</footer>

<script>
// Cart
let cartOpen=false;
function toggleCart(){cartOpen=!cartOpen;document.getElementById('cart-panel').classList.toggle('open',cartOpen);document.getElementById('cart-overlay').classList.toggle('open',cartOpen);if(cartOpen)loadCart();}
function closeCart(){cartOpen=false;document.getElementById('cart-panel').classList.remove('open');document.getElementById('cart-overlay').classList.remove('open');}

async function loadCart(){
  try{
    const r=await fetch('/cart/data');const{cart,total}=await r.json();
    const box=document.getElementById('cart-items');
    if(!cart||!cart.length){box.innerHTML='<div class="text-center font-mono text-xs text-slate-500 py-12">CART IS EMPTY</div>';document.getElementById('cart-total').textContent='$0';document.getElementById('cart-total-sol').textContent='—';return;}
    box.innerHTML=cart.map(i=>`<div class="flex items-start justify-between p-3 rounded-sm border border-dark-border gap-3"><div class="flex-1 min-w-0"><div class="font-display font-semibold text-sm text-white truncate">${i.name}</div><div class="font-mono text-xs text-brand-bright mt-1">$${i.price}</div></div><button onclick="removeFromCart('${i.id}')" class="text-slate-500 hover:text-red-400 text-sm flex-shrink-0">✕</button></div>`).join('');
    document.getElementById('cart-total').textContent='$'+total.toLocaleString();
    try{const pr=await fetch('/api/sol-price');const pd=await pr.json();if(pd.price>0){document.getElementById('cart-total-sol').textContent=(total/pd.price).toFixed(4)+' SOL';}}catch(e){}
  }catch(e){document.getElementById('cart-items').innerHTML='<div class="text-center text-red-500 font-mono text-xs py-8">FAILED TO LOAD CART</div>';}
}

async function addToCart(id){
  try{const r=await fetch('/cart/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({serviceId:id})});const d=await r.json();
  if(d.success){updateCartBadge(d.cartCount);showToast('Added to cart');if(cartOpen)loadCart();}else showToast(d.error||'Error');}catch(e){showToast('Network error');}
}
async function removeFromCart(id){
  try{const r=await fetch('/cart/remove',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({serviceId:id})});const d=await r.json();updateCartBadge(d.cartCount);loadCart();}catch(e){}
}
function updateCartBadge(n){const b=document.getElementById('cart-badge');if(b){b.textContent=n;b.style.display=n>0?'flex':'none';}}

// Connect modal
function openConnectModal(){document.getElementById('conn-modal').classList.add('open');}
function closeConnectModal(){document.getElementById('conn-modal').classList.remove('open');resetModal();}
function resetModal(){document.getElementById('wallet-opts').classList.remove('hidden');document.getElementById('wallet-connecting').classList.add('hidden');const e=document.getElementById('wallet-error');e.classList.add('hidden');e.textContent='';}

async function connectWalletWith(address){
  try{const r=await fetch('/auth/wallet-connect',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address})});const d=await r.json();
  if(d.success){closeConnectModal();showToast('Wallet connected');setTimeout(()=>{window.location.href=d.isAdmin?'/admin':'/dashboard';},800);}else showWalletError(d.error||'Connection failed');}catch(e){showWalletError('Network error');}
}
async function connectPhantom(){if(!window.solana?.isPhantom)return showWalletError('Phantom not detected.');showConnecting();try{const r=await window.solana.connect();await connectWalletWith(r.publicKey.toString());}catch(e){showWalletError(e.message||'Rejected');}}
async function connectBackpack(){if(!window.backpack)return showWalletError('Backpack not detected.');showConnecting();try{await window.backpack.connect();await connectWalletWith(window.backpack.publicKey.toString());}catch(e){showWalletError(e.message||'Rejected');}}
async function connectSolflare(){if(!window.solflare?.isSolflare)return showWalletError('Solflare not detected.');showConnecting();try{await window.solflare.connect();await connectWalletWith(window.solflare.publicKey.toString());}catch(e){showWalletError(e.message||'Rejected');}}
async function disconnectWallet(){try{await fetch('/auth/wallet-disconnect',{method:'POST'});}catch(e){}window.location.href='/';}
function showConnecting(){document.getElementById('wallet-opts').classList.add('hidden');document.getElementById('wallet-connecting').classList.remove('hidden');}
function showWalletError(m){resetModal();const e=document.getElementById('wallet-error');e.textContent=m;e.classList.remove('hidden');}

// Toast
function showToast(m){const t=document.getElementById('toast');t.textContent=m;t.style.opacity='1';setTimeout(()=>t.style.opacity='0',2600);}

document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeConnectModal();closeCart();}});
const _p=new URLSearchParams(window.location.search);
if(_p.get('connectRequired'))setTimeout(openConnectModal,400);
</script>
</body>
</html>
