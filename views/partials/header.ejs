<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { core:'#1a6fff', bright:'#4d9fff', pale:'#a8d0ff' },
            dark:  { bg:'#03050f', card:'#080d1a', border:'#0f1e3a' }
          },
          fontFamily: {
            display: ['Syne','sans-serif'],
            mono:    ['Space Mono','monospace'],
            body:    ['DM Sans','sans-serif']
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    body { font-family:'DM Sans',sans-serif; background:#03050f; color:#e8f0ff; overflow-x:hidden; }
    #stars-canvas { position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none; }
    .nebula { position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;
      background:radial-gradient(ellipse 80% 60% at 10% 20%,rgba(10,30,100,0.4) 0%,transparent 60%),
                 radial-gradient(ellipse 60% 80% at 90% 80%,rgba(5,20,80,0.35) 0%,transparent 60%),
                 radial-gradient(ellipse 40% 40% at 50% 50%,rgba(0,10,40,0.2) 0%,transparent 60%); }
    .layer { position:relative;z-index:10; }
    /* Scrollbar */
    ::-webkit-scrollbar{width:4px} ::-webkit-scrollbar-track{background:#03050f} ::-webkit-scrollbar-thumb{background:#0f1e3a;border-radius:2px} ::-webkit-scrollbar-thumb:hover{background:#1a6fff}
    /* Animations */
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    .fade-up{animation:fadeUp 0.6s ease forwards}
    .d1{animation-delay:0.1s;opacity:0}.d2{animation-delay:0.2s;opacity:0}.d3{animation-delay:0.3s;opacity:0}.d4{animation-delay:0.4s;opacity:0}
    /* Service card shimmer */
    .card{background:#080d1a;border:1px solid #0f1e3a;transition:all 0.25s;position:relative;overflow:hidden}
    .card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,#1a6fff,transparent);opacity:0;transition:opacity 0.3s}
    .card:hover{border-color:rgba(26,111,255,0.5);box-shadow:0 8px 40px rgba(26,111,255,0.15);transform:translateY(-3px)}
    .card:hover::before{opacity:1}
    /* Stat gradient text */
    .stat-num{font-family:'Syne',sans-serif;font-weight:800;font-size:2.5rem;background:linear-gradient(135deg,#fff,#4d9fff);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
    /* Section divider line */
    .sec-line{display:flex;align-items:center;gap:1rem}
    .sec-line::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,#0f1e3a,transparent)}
    /* Glow text */
    .text-glow{text-shadow:0 0 40px rgba(26,111,255,0.5),0 0 80px rgba(26,111,255,0.2)}
    /* Logo */
    .logo-img{filter:drop-shadow(0 0 12px rgba(26,111,255,0.6));transition:filter 0.3s}
    .logo-img:hover{filter:drop-shadow(0 0 24px rgba(77,159,255,0.9))}
    /* Wallet dropdown */
    #wdd{position:absolute;top:calc(100% + 8px);right:0;min-width:220px;background:#080d1a;border:1px solid #0f1e3a;border-radius:6px;z-index:500;display:none;box-shadow:0 8px 32px rgba(0,0,0,0.7)}
    #wdd.open{display:block}
    #wdd a,#wdd button{display:block;width:100%;text-align:left;padding:10px 16px;font-family:'Space Mono',monospace;font-size:0.7rem;color:#a8d0ff;background:transparent;border:none;cursor:pointer;text-decoration:none;transition:background 0.15s}
    #wdd a:hover,#wdd button:hover{background:rgba(26,111,255,0.12);color:#fff}
    #wdd .div{height:1px;background:#0f1e3a;margin:4px 0}
    /* Cart panel */
    #cart-panel{position:fixed;top:0;right:-100%;width:min(420px,100vw);height:100vh;background:rgba(3,8,20,0.97);backdrop-filter:blur(24px);border-left:1px solid #0f1e3a;z-index:200;transition:right 0.3s cubic-bezier(0.4,0,0.2,1);overflow-y:auto}
    #cart-panel.open{right:0}
    #cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:199;opacity:0;pointer-events:none;transition:opacity 0.3s}
    #cart-overlay.open{opacity:1;pointer-events:all}
    /* Connect modal */
    #conn-modal{position:fixed;inset:0;z-index:300;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.8);backdrop-filter:blur(10px);opacity:0;pointer-events:none;transition:opacity 0.3s}
    #conn-modal.open{opacity:1;pointer-events:all}
    /* Status badges */
    .sb{font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.08em;padding:2px 8px;border-radius:2px;text-transform:uppercase;white-space:nowrap}
    .s-pending_payment{background:rgba(255,170,0,0.15);color:#ffaa00;border:1px solid rgba(255,170,0,0.3)}
    .s-paid{background:rgba(0,255,136,0.1);color:#00ff88;border:1px solid rgba(0,255,136,0.3)}
    .s-in_progress{background:rgba(26,111,255,0.15);color:#4d9fff;border:1px solid rgba(26,111,255,0.4)}
    .s-review{background:rgba(136,0,255,0.15);color:#aa44ff;border:1px solid rgba(136,0,255,0.3)}
    .s-delivered{background:rgba(0,204,255,0.15);color:#00ccff;border:1px solid rgba(0,204,255,0.3)}
    .s-completed{background:rgba(0,255,68,0.1);color:#00ff44;border:1px solid rgba(0,255,68,0.3)}
    .s-cancelled{background:rgba(255,34,68,0.1);color:#ff2244;border:1px solid rgba(255,34,68,0.3)}
    /* Pills/badges */
    .badge-new{background:linear-gradient(90deg,#1a6fff,#00d4ff);font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.08em;padding:2px 8px;border-radius:2px;color:#fff}
    .badge-hot{background:linear-gradient(90deg,#ff4444,#ff8800);font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.08em;padding:2px 8px;border-radius:2px;color:#fff}
    .badge-test{background:rgba(100,100,100,0.2);font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.08em;padding:2px 8px;border-radius:2px;color:#888;border:1px solid rgba(150,150,150,0.25)}
    /* Chat bubbles */
    .bubble{max-width:78%;padding:10px 14px;border-radius:4px;font-size:0.875rem;line-height:1.5;word-break:break-word}
    .b-client{background:rgba(26,111,255,0.15);border:1px solid rgba(26,111,255,0.25);margin-left:auto}
    .b-developer{background:rgba(0,200,100,0.1);border:1px solid rgba(0,200,100,0.25)}
    .b-admin{background:rgba(255,170,0,0.1);border:1px solid rgba(255,170,0,0.25)}
    /* Field */
    .field{background:#03050f;border:1px solid #0f1e3a;color:#e8f0ff;padding:10px 14px;font-family:'DM Sans',sans-serif;font-size:0.875rem;outline:none;transition:border-color 0.2s;width:100%;border-radius:4px}
    .field:focus{border-color:#1a6fff}
    .field::placeholder{color:#3a4a6a}
    /* Drop zone */
    .dropzone{border:2px dashed #0f1e3a;border-radius:6px;padding:20px;text-align:center;cursor:pointer;transition:border-color 0.2s}
    .dropzone:hover,.dropzone.over{border-color:#1a6fff}
    /* Category pill */
    .cpill{font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:#4d9fff;border:1px solid rgba(26,111,255,0.3);background:rgba(26,111,255,0.08);padding:4px 14px;border-radius:2px;cursor:pointer;transition:all 0.2s;white-space:nowrap}
    .cpill:hover,.cpill.active{background:rgba(26,111,255,0.2);border-color:#1a6fff;color:#fff}
    /* Mobile menu */
    #mobile-menu{display:none}
    #mobile-menu.open{display:block}
  </style>
</head>
<body class="bg-dark-bg text-slate-100 font-body">
<canvas id="stars-canvas"></canvas>
<div class="nebula"></div>

<% const isHomePage = typeof locals.isHomePage !== 'undefined' ? locals.isHomePage : false; %>

<!-- NAV -->
<nav class="fixed top-0 left-0 right-0 z-50 border-b border-dark-border" style="background:rgba(3,5,15,0.9);backdrop-filter:blur(20px)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between gap-3">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
      <img src="/images/logo.jpg" alt="Blue Brick" class="logo-img w-8 h-8 sm:w-10 sm:h-10 object-cover rounded-sm" />
      <span class="font-display font-bold text-base sm:text-xl tracking-tight text-white">BLUE <span class="text-brand-core">BRICK</span></span>
    </a>

    <!-- Desktop center -->
    <div class="hidden md:flex items-center gap-5">
      <% if (isHomePage) { %>
        <a href="#services" class="font-mono text-xs tracking-widest text-slate-400 hover:text-white transition-colors">SERVICES</a>
      <% } %>
      <div class="flex items-center gap-2 px-3 py-1 rounded-sm border font-mono text-xs" style="border-color:rgba(26,111,255,0.25);background:rgba(26,111,255,0.08);color:#4d9fff">
        <span class="text-brand-pale">◎ SOL</span>
        <span id="nav-sol-price" class="text-white font-bold">
          <%= typeof solPrice !== 'undefined' && solPrice ? '$' + Number(solPrice).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}) : '...' %>
        </span>
      </div>
      <% if (isHomePage) { %>
        <a href="#stats" class="font-mono text-xs tracking-widest text-slate-400 hover:text-white transition-colors">STATS</a>
      <% } %>
    </div>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <!-- SOL ticker mobile -->
      <div class="flex md:hidden items-center gap-1 px-2 py-1 rounded-sm border font-mono text-xs" style="border-color:rgba(26,111,255,0.25);background:rgba(26,111,255,0.08);color:#4d9fff">
        <span class="text-brand-pale hidden xs:inline">◎</span>
        <span id="nav-sol-price-mob" class="text-white font-bold">
          <%= typeof solPrice !== 'undefined' && solPrice ? '$' + Number(solPrice).toFixed(0) : '...' %>
        </span>
      </div>

      <!-- Cart -->
      <button onclick="toggleCart()" class="relative font-mono text-xs px-3 py-2 rounded-sm border border-brand-core text-brand-pale hover:bg-brand-core hover:text-white transition-all">
        <span class="hidden sm:inline">CART</span>
        <span class="sm:hidden">🛒</span>
        <span id="cart-badge" class="absolute -top-1 -right-1 w-4 h-4 rounded-full text-white flex items-center justify-center font-mono bg-brand-core" style="font-size:0.55rem;display:<%= cartCount > 0 ? 'flex' : 'none' %>"><%= cartCount %></span>
      </button>

      <% if (locals.walletAddress) { %>
        <div class="relative" id="wallet-wrapper">
          <button onclick="toggleWDD()" class="flex items-center gap-1.5 px-3 py-2 rounded-sm border font-mono text-xs cursor-pointer transition-all" style="background:rgba(26,111,255,0.12);border-color:rgba(26,111,255,0.3);color:#a8d0ff">
            <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:#00ff88;box-shadow:0 0 5px #00ff88"></span>
            <span class="hidden sm:inline"><%= walletAddress.slice(0,4) %>...<%= walletAddress.slice(-4) %></span>
            <span class="sm:hidden"><%= walletAddress.slice(0,4) %>…</span>
            <span class="text-slate-500 text-xs">▼</span>
          </button>
          <div id="wdd">
            <a href="/dashboard" class="flex items-center gap-2"><span class="text-brand-core">◈</span> Dashboard</a>
            <% if (locals.isAdmin) { %><a href="/admin" style="color:#ffaa00"><span>⬡</span> Admin Panel</a><% } %>
            <% if (locals.isDeveloper && !locals.isAdmin) { %><a href="/developer" style="color:#00ff88"><span>⬡</span> Dev Dashboard</a><% } %>
            <div class="div"></div>
            <div class="px-4 py-2 font-mono text-slate-600 break-all" style="font-size:0.6rem"><%= walletAddress %></div>
            <div class="div"></div>
            <button onclick="disconnectWallet()" class="text-red-400 hover:text-red-300">✕ Disconnect</button>
          </div>
        </div>
      <% } else { %>
        <button onclick="openConnectModal()" class="font-mono text-xs px-4 py-2 rounded-sm text-white transition-all hover:opacity-90 active:scale-95" style="background:#1a6fff;letter-spacing:0.05em">
          <span class="hidden sm:inline">CONNECT WALLET</span>
          <span class="sm:hidden">CONNECT</span>
        </button>
      <% } %>
    </div>
  </div>
</nav>

<script>
(function(){
  const c=document.getElementById('stars-canvas'),ctx=c.getContext('2d');let s=[];
  function r(){c.width=innerWidth;c.height=innerHeight;}
  function init(){s=[];for(let i=0;i<260;i++)s.push({x:Math.random()*c.width,y:Math.random()*c.height,r:Math.random()*1.4+0.2,a:Math.random(),sp:Math.random()*0.3+0.05,tw:Math.random()*Math.PI*2});}
  function draw(){ctx.clearRect(0,0,c.width,c.height);s.forEach(s=>{s.tw+=s.sp*0.02;const o=0.3+0.7*Math.abs(Math.sin(s.tw));ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fillStyle=`rgba(168,208,255,${o*s.a})`;ctx.fill();});requestAnimationFrame(draw);}
  r();init();draw();window.addEventListener('resize',()=>{r();init();});
})();

setInterval(async()=>{
  try{const r=await fetch('/api/sol-price');const d=await r.json();if(d.price){
    const fmt=n=>n.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
    const el=document.getElementById('nav-sol-price');if(el)el.textContent='$'+fmt(d.price);
    const el2=document.getElementById('nav-sol-price-mob');if(el2)el2.textContent='$'+Math.round(d.price);
  }}catch(e){}
},60000);

function toggleWDD(){const d=document.getElementById('wdd');if(d)d.classList.toggle('open');}
document.addEventListener('click',e=>{
  const w=document.getElementById('wallet-wrapper');
  if(w&&!w.contains(e.target)){const d=document.getElementById('wdd');if(d)d.classList.remove('open');}
});
</script>
