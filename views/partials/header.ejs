<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root { --blue-core:#1a6fff; --blue-bright:#4d9fff; --blue-pale:#a8d0ff; --dark-bg:#03050f; --dark-card:#080d1a; --dark-border:#0f1e3a; }
    * { box-sizing:border-box; }
    body { background:var(--dark-bg); color:#e8f0ff; font-family:'DM Sans',sans-serif; overflow-x:hidden; }
    .font-display { font-family:'Syne',sans-serif; }
    .font-mono { font-family:'Space Mono',monospace; }
    #stars-canvas { position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; pointer-events:none; }
    .nebula { position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; pointer-events:none;
      background:radial-gradient(ellipse 80% 60% at 10% 20%,rgba(10,30,100,0.4) 0%,transparent 60%),
                 radial-gradient(ellipse 60% 80% at 90% 80%,rgba(5,20,80,0.35) 0%,transparent 60%),
                 radial-gradient(ellipse 40% 40% at 50% 50%,rgba(0,10,40,0.2) 0%,transparent 60%); }
    .content-layer { position:relative; z-index:10; }
    nav { position:fixed; top:0; left:0; right:0; z-index:100; background:rgba(3,5,15,0.85); backdrop-filter:blur(20px); border-bottom:1px solid var(--dark-border); }
    .btn-glow { background:var(--blue-core); color:#fff; border:none; cursor:pointer; transition:all 0.2s; font-family:'Space Mono',monospace; font-size:0.75rem; letter-spacing:0.05em; }
    .btn-glow:hover { background:var(--blue-bright); box-shadow:0 0 24px rgba(26,111,255,0.6),0 0 60px rgba(26,111,255,0.2); transform:translateY(-1px); }
    .btn-outline { background:transparent; border:1px solid var(--blue-core); color:var(--blue-pale); cursor:pointer; transition:all 0.2s; font-family:'Space Mono',monospace; font-size:0.75rem; }
    .btn-outline:hover { background:rgba(26,111,255,0.1); border-color:var(--blue-bright); color:#fff; box-shadow:0 0 16px rgba(26,111,255,0.3); }
    .service-card { background:var(--dark-card); border:1px solid var(--dark-border); transition:all 0.3s; position:relative; overflow:hidden; }
    .service-card::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,var(--blue-core),transparent); opacity:0; transition:opacity 0.3s; }
    .service-card:hover { border-color:rgba(26,111,255,0.5); box-shadow:0 8px 40px rgba(26,111,255,0.15); transform:translateY(-4px); }
    .service-card:hover::before { opacity:1; }
    .badge-new { background:linear-gradient(90deg,#1a6fff,#00d4ff); font-family:'Space Mono',monospace; font-size:0.6rem; letter-spacing:0.1em; padding:2px 8px; border-radius:2px; }
    .badge-hot { background:linear-gradient(90deg,#ff4444,#ff8800); font-family:'Space Mono',monospace; font-size:0.6rem; letter-spacing:0.1em; padding:2px 8px; border-radius:2px; }
    .badge-test { background:rgba(100,100,100,0.3); font-family:'Space Mono',monospace; font-size:0.6rem; letter-spacing:0.1em; padding:2px 8px; border-radius:2px; color:#aaa; border:1px solid rgba(150,150,150,0.3); }
    .category-pill { font-family:'Space Mono',monospace; font-size:0.65rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--blue-bright); border:1px solid rgba(26,111,255,0.3); background:rgba(26,111,255,0.08); padding:4px 14px; border-radius:2px; cursor:pointer; transition:all 0.2s; }
    .category-pill:hover,.category-pill.active { background:rgba(26,111,255,0.2); border-color:var(--blue-core); color:#fff; }
    #cart-panel { position:fixed; top:0; right:-420px; width:420px; height:100vh; background:rgba(3,8,20,0.97); backdrop-filter:blur(30px); border-left:1px solid var(--dark-border); z-index:200; transition:right 0.3s cubic-bezier(0.4,0,0.2,1); overflow-y:auto; }
    #cart-panel.open { right:0; }
    #cart-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:199; opacity:0; pointer-events:none; transition:opacity 0.3s; }
    #cart-overlay.open { opacity:1; pointer-events:all; }
    ::-webkit-scrollbar { width:4px; }
    ::-webkit-scrollbar-track { background:var(--dark-bg); }
    ::-webkit-scrollbar-thumb { background:var(--dark-border); border-radius:2px; }
    ::-webkit-scrollbar-thumb:hover { background:var(--blue-core); }
    .section-line { display:flex; align-items:center; gap:16px; }
    .section-line::after { content:''; flex:1; height:1px; background:linear-gradient(90deg,var(--dark-border),transparent); }
    .text-glow { text-shadow:0 0 40px rgba(26,111,255,0.5),0 0 80px rgba(26,111,255,0.2); }
    .wallet-chip { font-family:'Space Mono',monospace; font-size:0.7rem; background:rgba(26,111,255,0.12); border:1px solid rgba(26,111,255,0.3); color:var(--blue-pale); padding:4px 12px; border-radius:2px; cursor:pointer; transition:all 0.2s; position:relative; }
    .wallet-chip:hover { background:rgba(26,111,255,0.2); border-color:var(--blue-bright); }
    /* Wallet dropdown */
    #wallet-dropdown { position:absolute; top:calc(100% + 8px); right:0; min-width:200px; background:var(--dark-card); border:1px solid var(--dark-border); border-radius:4px; z-index:500; display:none; box-shadow:0 8px 32px rgba(0,0,0,0.6); }
    #wallet-dropdown.open { display:block; }
    #wallet-dropdown a, #wallet-dropdown button { display:block; width:100%; text-align:left; padding:10px 16px; font-family:'Space Mono',monospace; font-size:0.7rem; color:var(--blue-pale); background:transparent; border:none; cursor:pointer; transition:background 0.15s; text-decoration:none; }
    #wallet-dropdown a:hover, #wallet-dropdown button:hover { background:rgba(26,111,255,0.1); color:#fff; }
    #wallet-dropdown .dd-divider { height:1px; background:var(--dark-border); margin:4px 0; }
    #wallet-dropdown .dd-disconnect { color:#ff5566; }
    #wallet-dropdown .dd-disconnect:hover { background:rgba(255,34,68,0.1); color:#ff8899; }
    #connect-modal { position:fixed; inset:0; z-index:300; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,0.8); backdrop-filter:blur(10px); opacity:0; pointer-events:none; transition:opacity 0.3s; }
    #connect-modal.open { opacity:1; pointer-events:all; }
    .modal-box { background:var(--dark-card); border:1px solid var(--dark-border); width:440px; max-width:95vw; padding:40px; position:relative; border-radius:4px; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
    .fade-up { animation:fadeUp 0.6s ease forwards; }
    .delay-1{animation-delay:0.1s;opacity:0} .delay-2{animation-delay:0.2s;opacity:0} .delay-3{animation-delay:0.3s;opacity:0} .delay-4{animation-delay:0.4s;opacity:0}
    .logo-img { filter:drop-shadow(0 0 16px rgba(26,111,255,0.6)); transition:filter 0.3s; }
    .logo-img:hover { filter:drop-shadow(0 0 28px rgba(77,159,255,0.9)); }
    .stat-num { font-family:'Syne',sans-serif; font-weight:800; font-size:2.5rem; background:linear-gradient(135deg,#fff,var(--blue-bright)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
    .sol-ticker { font-family:'Space Mono',monospace; font-size:0.7rem; color:var(--blue-bright); background:rgba(26,111,255,0.1); border:1px solid rgba(26,111,255,0.25); padding:3px 10px; border-radius:2px; }
    .status-badge { font-family:'Space Mono',monospace; font-size:0.6rem; letter-spacing:0.1em; padding:2px 8px; border-radius:2px; text-transform:uppercase; }
    .status-pending_payment{background:rgba(255,170,0,0.15);color:#ffaa00;border:1px solid rgba(255,170,0,0.3)}
    .status-paid{background:rgba(0,255,136,0.1);color:#00ff88;border:1px solid rgba(0,255,136,0.3)}
    .status-in_progress{background:rgba(26,111,255,0.15);color:#4d9fff;border:1px solid rgba(26,111,255,0.4)}
    .status-review{background:rgba(136,0,255,0.15);color:#aa44ff;border:1px solid rgba(136,0,255,0.3)}
    .status-delivered{background:rgba(0,204,255,0.15);color:#00ccff;border:1px solid rgba(0,204,255,0.3)}
    .status-completed{background:rgba(0,255,68,0.1);color:#00ff44;border:1px solid rgba(0,255,68,0.3)}
    .status-cancelled{background:rgba(255,34,68,0.1);color:#ff2244;border:1px solid rgba(255,34,68,0.3)}
    .timeline-dot{width:10px;height:10px;border-radius:50%;background:var(--blue-core);flex-shrink:0;box-shadow:0 0 8px rgba(26,111,255,0.6)}
    .timeline-line{width:1px;flex:1;background:linear-gradient(180deg,var(--blue-core),transparent);min-height:24px}
    /* Chat styles */
    .chat-bubble { max-width:80%; padding:10px 14px; border-radius:4px; font-size:0.875rem; line-height:1.5; word-break:break-word; }
    .chat-client { background:rgba(26,111,255,0.15); border:1px solid rgba(26,111,255,0.25); margin-left:auto; }
    .chat-developer { background:rgba(0,200,100,0.1); border:1px solid rgba(0,200,100,0.25); }
    .chat-admin { background:rgba(255,170,0,0.1); border:1px solid rgba(255,170,0,0.25); }
    .chat-input { background:var(--dark-bg); border:1px solid var(--dark-border); color:#e8f0ff; padding:10px 14px; font-family:'DM Sans',sans-serif; font-size:0.875rem; outline:none; transition:border-color 0.2s; }
    .chat-input:focus { border-color:var(--blue-core); }
    .chat-input::placeholder { color:#3a4a6a; }
  </style>
</head>
<body>
<canvas id="stars-canvas"></canvas>
<div class="nebula"></div>

<%
  // Detect if this is the homepage to conditionally show nav links
  const isHomePage = typeof locals.isHomePage !== 'undefined' ? locals.isHomePage : false;
%>

<nav>
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <img src="/images/logo.jpg" alt="Blue Brick" class="logo-img w-10 h-10 object-cover rounded-sm" />
      <span class="font-display font-bold text-xl tracking-tight text-white">BLUE <span style="color:var(--blue-core)">BRICK</span></span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      <% if (isHomePage) { %>
        <a href="#services" class="font-mono text-xs tracking-widest text-slate-400 hover:text-white transition-colors">SERVICES</a>
      <% } %>
      <!-- SOL price ticker — always visible -->
      <div class="sol-ticker flex items-center gap-2">
        <span style="color:var(--blue-pale)">◎ SOL</span>
        <span id="nav-sol-price" class="text-white font-bold">
          <%= typeof solPrice !== 'undefined' && solPrice ? '$' + Number(solPrice).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}) : '...' %>
        </span>
      </div>
      <% if (isHomePage) { %>
        <a href="#stats" class="font-mono text-xs tracking-widest text-slate-400 hover:text-white transition-colors">STATS</a>
      <% } %>
    </div>

    <div class="flex items-center gap-3">
      <!-- Cart -->
      <button onclick="toggleCart()" class="btn-outline px-4 py-2 rounded-sm relative">
        <span>CART</span>
        <span id="cart-badge" class="absolute -top-1 -right-1 w-4 h-4 rounded-full text-xs flex items-center justify-center font-mono" style="background:var(--blue-core);font-size:0.6rem;display:<%= cartCount > 0 ? 'flex' : 'none' %>"><%= cartCount %></span>
      </button>

      <% if (locals.walletAddress) { %>
        <!-- Wallet button with dropdown -->
        <div class="relative" id="wallet-wrapper">
          <button onclick="toggleWalletDropdown()" class="wallet-chip flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background:#00ff88; box-shadow:0 0 6px #00ff88; flex-shrink:0;"></span>
            <span><%= walletAddress.slice(0,4) %>...<%= walletAddress.slice(-4) %></span>
            <span class="text-slate-500" style="font-size:0.6rem;">▼</span>
          </button>
          <div id="wallet-dropdown">
            <a href="/dashboard">◈ Dashboard</a>
            <% if (locals.isAdmin) { %><a href="/admin" style="color:#ffaa00;">⬡ Admin Panel</a><% } %>
            <% if (locals.isDeveloper && !locals.isAdmin) { %><a href="/developer" style="color:#00ff88;">⬡ Dev Dashboard</a><% } %>
            <div class="dd-divider"></div>
            <div class="px-4 py-2 font-mono" style="font-size:0.6rem; color:#3a4a6a; word-break:break-all;"><%= walletAddress %></div>
            <div class="dd-divider"></div>
            <button onclick="disconnectWallet()" class="dd-disconnect">✕ Disconnect</button>
          </div>
        </div>
      <% } else { %>
        <button onclick="openConnectModal()" class="btn-glow px-5 py-2 rounded-sm">CONNECT WALLET</button>
      <% } %>
    </div>
  </div>
</nav>

<script>
(function(){
  const c=document.getElementById('stars-canvas'),ctx=c.getContext('2d');let s=[];
  function r(){c.width=window.innerWidth;c.height=window.innerHeight;}
  function init(){s=[];for(let i=0;i<280;i++)s.push({x:Math.random()*c.width,y:Math.random()*c.height,r:Math.random()*1.5+0.2,a:Math.random(),sp:Math.random()*0.3+0.05,tw:Math.random()*Math.PI*2});}
  function draw(){ctx.clearRect(0,0,c.width,c.height);s.forEach(s=>{s.tw+=s.sp*0.02;const o=0.3+0.7*Math.abs(Math.sin(s.tw));ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fillStyle=`rgba(168,208,255,${o*s.a})`;ctx.fill();});requestAnimationFrame(draw);}
  r();init();draw();window.addEventListener('resize',()=>{r();init();});
})();

// SOL price auto-refresh
setInterval(async()=>{
  try{const r=await fetch('/api/sol-price');const d=await r.json();if(d.price){const el=document.getElementById('nav-sol-price');if(el)el.textContent='$'+Number(d.price).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});}}catch(e){}
},60000);

// Wallet dropdown
function toggleWalletDropdown(){
  const dd=document.getElementById('wallet-dropdown');
  if(dd) dd.classList.toggle('open');
}
// Close dropdown on outside click
document.addEventListener('click',e=>{
  const wrapper=document.getElementById('wallet-wrapper');
  if(wrapper && !wrapper.contains(e.target)){
    const dd=document.getElementById('wallet-dropdown');
    if(dd) dd.classList.remove('open');
  }
});
</script>
