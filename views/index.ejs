<%- include('partials/header') %>
<% locals.isHomePage = true; %>

<div class="layer">
  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center items-center text-center px-4 sm:px-6 pt-20 pb-12 relative">
    <div class="fade-up d1 mb-6">
      <img src="/images/logo.jpg" alt="Blue Brick" class="logo-img w-24 h-24 sm:w-32 sm:h-32 object-cover rounded-lg mx-auto" style="box-shadow:0 0 60px rgba(26,111,255,0.4)" />
    </div>
    <div class="fade-up d2">
      <p class="font-mono text-xs tracking-[0.3em] mb-4 text-brand-core">SOLANA DEVELOPMENT AGENCY</p>
      <h1 class="font-display font-extrabold text-glow leading-none mb-5" style="font-size:clamp(2.8rem,10vw,7rem)">
        BLUE<br><span class="text-brand-core">BRICK</span>
      </h1>
      <p class="text-slate-300 text-base sm:text-lg max-w-xl mx-auto leading-relaxed font-light px-2">
        We architect tokens, dApps, DeFi protocols, and brands on Solana.<br class="hidden sm:block"> From idea to mainnet — full stack, full speed.
      </p>
    </div>
    <div class="fade-up d3 mt-8 sm:mt-10">
      <a href="#services" class="inline-block font-mono text-xs px-6 sm:px-8 py-3 sm:py-4 rounded-sm text-white transition-all hover:opacity-90 active:scale-95" style="background:#1a6fff;letter-spacing:0.05em">EXPLORE SERVICES</a>
    </div>
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30">
      <span class="font-mono text-xs tracking-widest text-brand-pale">SCROLL</span>
      <div class="w-px h-8 bg-gradient-to-b from-blue-500 to-transparent animate-pulse"></div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="py-12 sm:py-16 border-y border-dark-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-10">
      <div class="flex gap-4 items-start">
        <div class="text-2xl mt-1 flex-shrink-0">⚡</div>
        <div><h3 class="font-display font-bold text-base sm:text-lg mb-1 sm:mb-2 text-white">Lightning Fast</h3><p class="text-slate-400 text-sm leading-relaxed">Solana 50,000+ TPS at sub-cent fees. We build apps that leverage this raw speed.</p></div>
      </div>
      <div class="flex gap-4 items-start">
        <div class="text-2xl mt-1 flex-shrink-0">🔩</div>
        <div><h3 class="font-display font-bold text-base sm:text-lg mb-1 sm:mb-2 text-white">Rust-First</h3><p class="text-slate-400 text-sm leading-relaxed">Every smart contract in Rust/Anchor — memory safe, auditable, production-grade from day one.</p></div>
      </div>
      <div class="flex gap-4 items-start">
        <div class="text-2xl mt-1 flex-shrink-0">🎯</div>
        <div><h3 class="font-display font-bold text-base sm:text-lg mb-1 sm:mb-2 text-white">Ecosystem Native</h3><p class="text-slate-400 text-sm leading-relaxed">Deep integrations with Raydium, Jupiter, pump.fun, PumpSwap, Jito, and the full DeFi stack.</p></div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-16 sm:py-24 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto">
      <div class="sec-line mb-3"><span class="font-mono text-xs tracking-[0.3em] text-brand-core">WHAT WE BUILD</span></div>
      <h2 class="font-display font-extrabold text-3xl sm:text-5xl text-white mb-3">SERVICES</h2>
      <p class="text-slate-400 text-base sm:text-lg mb-8 max-w-xl">Production-ready, mainnet-deployed, handed over with docs.</p>

      <div class="flex flex-wrap gap-2 mb-10 overflow-x-auto pb-2">
        <button class="cpill active" onclick="filterCat('all',this)">ALL</button>
        <% Object.keys(categories).forEach(cat => { %>
          <button class="cpill" onclick="filterCat('<%= cat %>',this)"><%= cat.toUpperCase() %></button>
        <% }) %>
      </div>

      <% Object.entries(categories).forEach(([catName, catServices]) => { %>
      <div class="category-block mb-12 sm:mb-16" data-cat="<%= catName %>">
        <div class="sec-line mb-6 sm:mb-8"><span class="font-mono text-xs tracking-widest text-slate-400"><%= catName.toUpperCase() %></span></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
          <% catServices.forEach(service => { %>
          <a href="/services/<%= service.id %>" class="card rounded-sm p-5 sm:p-6 block no-underline">
            <div class="flex items-start justify-between mb-4">
              <span class="text-2xl sm:text-3xl"><%= service.icon %></span>
              <div class="flex items-center gap-2 flex-wrap justify-end">
                <% if (service.badge==='NEW') { %><span class="badge-new">NEW</span><% } %>
                <% if (service.badge==='HOT') { %><span class="badge-hot">HOT</span><% } %>
                <% if (service.badge==='TEST') { %><span class="badge-test">TEST</span><% } %>
              </div>
            </div>
            <h3 class="font-display font-bold text-base sm:text-lg mb-2 text-white leading-tight"><%= service.name %></h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-4"><%= service.description.substring(0,100) %>...</p>
            <ul class="grid grid-cols-2 gap-1 mb-4">
              <% service.features.slice(0,4).forEach(f => { %>
                <li class="font-mono text-xs text-slate-500 flex items-center gap-1 truncate"><span class="text-brand-core">◈</span> <%= f %></li>
              <% }) %>
            </ul>
            <div class="flex items-center justify-between pt-3 border-t border-dark-border">
              <span class="font-mono text-xs text-slate-500">VIEW DETAILS</span>
              <span class="font-mono text-xs text-brand-bright">→</span>
            </div>
          </a>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>
  </section>

  <!-- STATS -->
  <section id="stats" class="py-16 sm:py-24 px-4 sm:px-6 border-y border-dark-border">
    <div class="max-w-7xl mx-auto">
      <div class="sec-line mb-10 sm:mb-12"><span class="font-mono text-xs tracking-[0.3em] text-brand-core">BY THE NUMBERS</span></div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-10">
        <div><div class="stat-num">100+</div><div class="font-mono text-xs text-slate-500 tracking-widest mt-2">PROJECTS SHIPPED</div></div>
        <div><div class="stat-num">30+</div><div class="font-mono text-xs text-slate-500 tracking-widest mt-2">SERVICES OFFERED</div></div>
        <div><div class="stat-num">99.9%</div><div class="font-mono text-xs text-slate-500 tracking-widest mt-2">UPTIME GUARANTEE</div></div>
        <div><div class="stat-num">48H</div><div class="font-mono text-xs text-slate-500 tracking-widest mt-2">AVG DELIVERY</div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 sm:py-32 px-4 sm:px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <p class="font-mono text-xs tracking-[0.3em] mb-4 text-brand-core">READY TO BUILD?</p>
      <h2 class="font-display font-extrabold text-glow mb-5" style="font-size:clamp(2rem,6vw,5rem)">LET'S LAUNCH ON SOLANA</h2>
      <p class="text-slate-400 mb-8 text-base sm:text-lg">Connect your wallet, browse services, and submit your order. We'll reach out within 24 hours.</p>
      <% if (locals.walletAddress) { %>
        <a href="/dashboard" class="inline-block font-mono text-xs px-8 sm:px-10 py-3 sm:py-4 rounded-sm text-white" style="background:#1a6fff;letter-spacing:0.05em">OPEN DASHBOARD →</a>
      <% } else { %>
        <a href="#services" class="inline-block font-mono text-xs px-8 sm:px-10 py-3 sm:py-4 rounded-sm text-white" style="background:#1a6fff;letter-spacing:0.05em">BROWSE SERVICES →</a>
      <% } %>
    </div>
  </section>
</div>

<script>
function filterCat(cat,btn){
  document.querySelectorAll('.cpill').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.category-block').forEach(b=>{b.style.display=(cat==='all'||b.dataset.cat===cat)?'block':'none';});
}
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{const t=document.querySelector(a.getAttribute('href'));if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}});
});
</script>
<%- include('partials/footer') %>
