<%- include('partials/header') %>
<div class="layer pt-24 sm:pt-28 min-h-screen">
<div class="max-w-7xl mx-auto px-4 sm:px-6 pb-16 sm:pb-24">

  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8 pb-6 border-b border-dark-border">
    <div>
      <p class="font-mono text-xs tracking-[0.3em] mb-1" style="color:#ffaa00">ADMIN PANEL</p>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-white">ORDER CONTROL</h1>
    </div>
    <a href="/dashboard" class="font-mono text-xs px-4 py-2 rounded-sm border border-brand-core text-brand-pale hover:bg-brand-core hover:text-white transition-all self-start sm:self-auto">USER VIEW</a>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3 mb-10 sm:mb-12">
    <div class="card rounded-sm p-3 sm:p-4 text-center"><div class="font-display font-bold text-xl sm:text-2xl text-white"><%= stats.total %></div><div class="font-mono text-xs text-slate-500 mt-1">TOTAL</div></div>
    <div class="card rounded-sm p-3 sm:p-4 text-center"><div class="font-display font-bold text-xl sm:text-2xl" style="color:#ffaa00"><%= stats.pending %></div><div class="font-mono text-xs text-slate-500 mt-1">PENDING</div></div>
    <div class="card rounded-sm p-3 sm:p-4 text-center"><div class="font-display font-bold text-xl sm:text-2xl" style="color:#00ff88"><%= stats.paid %></div><div class="font-mono text-xs text-slate-500 mt-1">PAID</div></div>
    <div class="card rounded-sm p-3 sm:p-4 text-center"><div class="font-display font-bold text-xl sm:text-2xl text-brand-bright"><%= stats.inProgress %></div><div class="font-mono text-xs text-slate-500 mt-1">BUILDING</div></div>
    <div class="card rounded-sm p-3 sm:p-4 text-center"><div class="font-display font-bold text-xl sm:text-2xl" style="color:#aa44ff"><%= stats.delivered %></div><div class="font-mono text-xs text-slate-500 mt-1">DELIVERED</div></div>
    <div class="card rounded-sm p-3 sm:p-4 text-center"><div class="font-display font-bold text-xl sm:text-2xl" style="color:#00ff44"><%= stats.completed %></div><div class="font-mono text-xs text-slate-500 mt-1">DONE</div></div>
    <div class="card rounded-sm p-3 sm:p-4 text-center col-span-2 sm:col-span-1"><div class="font-display font-bold text-xl sm:text-2xl text-brand-bright">$<%= stats.revenue.toLocaleString() %></div><div class="font-mono text-xs text-slate-500 mt-1">REVENUE</div></div>
  </div>

  <!-- Developer Registry -->
  <div class="card rounded-sm p-5 sm:p-6 mb-8 sm:mb-10">
    <div class="sec-line mb-5"><span class="font-mono text-xs tracking-widest" style="color:#ffaa00">DEVELOPER REGISTRY</span></div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h4 class="font-mono text-xs text-slate-400 mb-3">ADD / UPDATE DEVELOPER</h4>
        <div class="flex flex-col gap-2">
          <input id="dev-name" placeholder="Developer name" class="field" />
          <input id="dev-wallet" placeholder="Solana wallet address" class="field" />
          <button onclick="addDev()" class="font-mono text-xs py-2 rounded-sm text-white" style="background:#1a6fff">ADD DEVELOPER</button>
        </div>
        <div id="dev-status" class="hidden mt-2 font-mono text-xs p-2 rounded-sm"></div>
      </div>
      <div>
        <h4 class="font-mono text-xs text-slate-400 mb-3">REGISTERED (<%= devs.length %>)</h4>
        <% if (!devs.length) { %><p class="font-mono text-xs text-slate-600">No developers added yet.</p>
        <% } else { %>
        <div class="flex flex-col gap-2" id="dev-list">
          <% devs.forEach(dev => { %>
          <div class="flex items-center justify-between p-3 rounded-sm" id="dev-<%= dev.wallet %>" style="background:rgba(0,255,100,0.04);border:1px solid rgba(0,255,100,0.12)">
            <div>
              <div class="font-display font-semibold text-sm" style="color:#80ffcc"><%= dev.name %></div>
              <div class="font-mono text-xs text-slate-500 mt-0.5"><%= dev.wallet.slice(0,10) %>...<%= dev.wallet.slice(-6) %></div>
            </div>
            <button onclick="removeDev('<%= dev.wallet %>')" class="font-mono text-xs text-red-500 hover:text-red-400 ml-3">✕</button>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Orders -->
  <div class="sec-line mb-5 sm:mb-6"><span class="font-mono text-xs tracking-widest" style="color:#ffaa00">ALL ORDERS</span></div>
  <% if (!orders || !orders.length) { %>
    <div class="text-center py-14 font-mono text-slate-500">NO ORDERS YET</div>
  <% } else { %>
  <div class="flex flex-col gap-4">
    <% orders.forEach(order => { %>
    <div class="card rounded-sm p-4 sm:p-5" id="order-<%= order.id %>">
      <div class="flex flex-col lg:flex-row lg:items-start justify-between gap-4">
        <!-- Info -->
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <a href="/orders/<%= order.id %>" class="font-mono font-bold text-white hover:text-brand-bright transition-colors text-sm"><%= order.id %></a>
            <span class="sb s-<%= order.status %>"><%= order.status.replace(/_/g,' ') %></span>
            <span class="font-mono text-xs text-slate-500 hidden sm:inline"><%= new Date(order.createdAt).toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
          </div>
          <div class="font-mono text-xs text-slate-500 mb-2">
            CLIENT: <span class="text-slate-300"><%= order.wallet.slice(0,8) %>...<%= order.wallet.slice(-6) %></span>
            <% if (order.developerName) { %> · DEV: <span style="color:#00ff88"><%= order.developerName %></span><% } %>
          </div>
          <div class="flex flex-wrap gap-1 mb-2">
            <% order.items.forEach(item => { %><span class="font-mono text-xs px-2 py-0.5 rounded-sm text-brand-pale border border-dark-border" style="background:rgba(26,111,255,0.08)"><%= item.name %></span><% }) %>
          </div>
          <div class="font-mono text-xs text-slate-400">
            <span class="font-bold text-brand-bright">$<%= order.totalUSD %></span>
            <% if (order.txHash) { %> · <a href="https://solscan.io/tx/<%= order.txHash %>" target="_blank" class="text-brand-bright">TX ↗</a><% } %>
            <% if (order.projectDetails?.projectName) { %> · <span class="text-brand-bright"><%= order.projectDetails.projectName %></span><% } %>
          </div>
        </div>
        <!-- Controls -->
        <div class="flex flex-col gap-2 w-full lg:w-64 flex-shrink-0">
          <select id="status-<%= order.id %>" class="field text-xs py-2">
            <% ['pending_payment','paid','in_progress','review','delivered','completed','cancelled'].forEach(s => { %>
              <option value="<%= s %>" <%= order.status===s?'selected':'' %>><%= s.replace(/_/g,' ').toUpperCase() %></option>
            <% }) %>
          </select>
          <input type="text" id="note-<%= order.id %>" placeholder="Note for client..." class="field text-xs py-2" />
          <button onclick="updateStatus('<%= order.id %>')" class="font-mono text-xs py-2 rounded-sm text-white" style="background:#1a6fff">UPDATE STATUS</button>
          <div class="flex gap-2">
            <select id="devsel-<%= order.id %>" class="field text-xs py-2 flex-1">
              <option value="">Assign developer...</option>
              <% devs.forEach(dev => { %>
                <option value="<%= dev.wallet %>|<%= dev.name %>" <%= order.developerWallet===dev.wallet?'selected':'' %>><%= dev.name %></option>
              <% }) %>
            </select>
            <button onclick="assignDev('<%= order.id %>')" class="font-mono text-xs px-3 py-2 rounded-sm border border-brand-core text-brand-pale hover:bg-brand-core hover:text-white transition-all flex-shrink-0">ASSIGN</button>
          </div>
          <a href="/orders/<%= order.id %>" class="font-mono text-xs py-2 rounded-sm border border-dark-border text-slate-400 hover:text-white hover:border-slate-400 transition-all text-center">OPEN CHAT →</a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
</div>
<script>
async function updateStatus(id){
  const s=document.getElementById('status-'+id).value;
  const n=document.getElementById('note-'+id).value.trim();
  try{const r=await fetch('/admin/order/'+id+'/status',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:s,note:n})});const d=await r.json();
  if(d.success){showToast('Updated '+id);document.getElementById('note-'+id).value='';}else showToast(d.error||'Failed');}catch(e){showToast('Error');}
}
async function assignDev(id){
  const v=document.getElementById('devsel-'+id).value;
  if(!v)return showToast('Select a developer');
  const[wallet,name]=v.split('|');
  try{const r=await fetch('/admin/order/'+id+'/assign-dev',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({developerWallet:wallet,developerName:name})});const d=await r.json();
  if(d.success)showToast(name+' assigned');else showToast(d.error||'Failed');}catch(e){showToast('Error');}
}
async function addDev(){
  const name=document.getElementById('dev-name').value.trim();
  const wallet=document.getElementById('dev-wallet').value.trim();
  const st=document.getElementById('dev-status');
  if(!name||!wallet)return showToast('Name and wallet required');
  try{const r=await fetch('/admin/developers/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,wallet})});const d=await r.json();
  if(d.success){document.getElementById('dev-name').value='';document.getElementById('dev-wallet').value='';st.classList.remove('hidden');st.style.cssText='background:rgba(0,255,136,0.08);color:#00ff88;border:1px solid rgba(0,255,136,0.2);';st.textContent='Added '+d.dev.name;setTimeout(()=>location.reload(),1000);}else showToast(d.error||'Failed');}catch(e){showToast('Error');}
}
async function removeDev(wallet){
  try{const r=await fetch('/admin/developers/remove',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({wallet})});const d=await r.json();
  if(d.success){document.getElementById('dev-'+wallet)?.remove();showToast('Developer removed');}else showToast(d.error);}catch(e){showToast('Error');}
}
</script>
<%- include('partials/footer') %>
