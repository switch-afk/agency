<%- include('partials/header') %>
<div class="layer pt-24 sm:pt-28 min-h-screen">
<div class="max-w-2xl mx-auto px-4 sm:px-6 pb-16 sm:pb-24">
  <div class="mb-8 sm:mb-10">
    <p class="font-mono text-xs tracking-[0.3em] mb-2 text-brand-core">FINAL STEP</p>
    <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-white">CHECKOUT</h1>
    <p class="font-mono text-xs text-slate-500 mt-2 break-all">WALLET: <span class="text-brand-pale"><%= walletAddress %></span></p>
  </div>

  <% if (!cart || cart.length === 0) { %>
    <div class="text-center py-12"><p class="font-mono text-slate-500 mb-6">CART IS EMPTY</p><a href="/dashboard" class="inline-block font-mono text-xs px-8 py-3 rounded-sm text-white" style="background:#1a6fff">BROWSE SERVICES →</a></div>
  <% } else { %>

  <div class="card rounded-sm p-5 sm:p-6 mb-5">
    <h3 class="font-mono text-xs tracking-widest text-slate-400 mb-4">ORDER SUMMARY</h3>
    <% cart.forEach(item => { %>
    <div class="flex justify-between items-center py-2 border-b border-dark-border last:border-0">
      <span class="text-sm text-slate-200"><%= item.icon||'◈' %> <%= item.name %></span>
      <span class="font-mono text-sm text-brand-bright flex-shrink-0 ml-3"><%= item.price===0?'FREE':'$'+item.price %></span>
    </div>
    <% }) %>
    <div class="flex justify-between items-center pt-4 mt-2">
      <span class="font-mono text-xs text-slate-400">TOTAL DUE</span>
      <div class="text-right">
        <% if (total===0) { %>
          <div class="font-display font-bold text-2xl" style="color:#00ff88">FREE</div>
        <% } else { %>
          <div class="font-display font-bold text-2xl text-brand-bright">$<%= total %></div>
          <% if (solPrice && solTotal && parseFloat(solTotal) > 0) { %>
          <div class="font-mono text-xs text-slate-400 mt-1">≈ <span id="sol-amount"><%= solTotal %></span> SOL</div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>

  <div id="payment-status" class="hidden mb-4 p-4 rounded-sm font-mono text-sm border border-dark-border"></div>

  <% if (total === 0) { %>
    <div class="p-4 rounded-sm mb-5 font-mono text-xs" style="background:rgba(0,255,136,0.06);border:1px solid rgba(0,255,136,0.2);color:#00cc77">
      ◈ NO PAYMENT REQUIRED — FREE TEST ORDER<br>◈ ORDER CREATED INSTANTLY<br>◈ DISCORD NOTIFICATION WILL FIRE
    </div>
    <button onclick="placeFreeOrder()" id="pay-btn" class="w-full font-mono text-xs py-4 rounded-sm text-white mb-3 hover:opacity-90 transition-all" style="background:#1a6fff">PLACE ORDER →</button>

  <% } else if (agencyWallet && agencyWallet !== 'YourAgencyWalletPublicKeyHere') { %>
    <button onclick="initiatePayment()" id="pay-btn" class="w-full font-mono text-xs py-4 rounded-sm text-white mb-3 hover:opacity-90 transition-all" style="background:#1a6fff">
      PAY <%= (solPrice && solTotal) ? solTotal + ' SOL' : '$' + total %> NOW
    </button>
  <% } else { %>
    <div class="p-4 rounded-sm mb-4 font-mono text-xs text-yellow-400" style="background:rgba(255,170,0,0.08);border:1px solid rgba(255,170,0,0.3)">⚠ Agency wallet not configured in .env</div>
  <% } %>

  <a href="/cart" class="block w-full text-center font-mono text-xs py-3 rounded-sm border border-brand-core text-brand-pale hover:bg-brand-core hover:text-white transition-all">← BACK TO CART</a>
  <p class="font-mono text-xs text-slate-600 text-center mt-5">Payments processed on Solana Mainnet via QuickNode RPC</p>
  <% } %>
</div>
</div>
<script>
const QUICKNODE_RPC='<%= quicknodeRpc||"" %>';
const QUICKNODE_WSS='<%= quicknodeWss||"" %>';
const AGENCY_WALLET='<%= agencyWallet||"" %>';
const TOTAL_USD=<%= total||0 %>;
const SOL_TOTAL='<%= solTotal||"0" %>';
const SOL_PRICE=<%= solPrice||0 %>;

function setStat(m,t){const el=document.getElementById('payment-status');if(!el)return;el.classList.remove('hidden');const c={info:'rgba(26,111,255,0.1)|rgba(26,111,255,0.3)|#4d9fff',success:'rgba(0,255,136,0.08)|rgba(0,255,136,0.3)|#00ff88',error:'rgba(255,34,68,0.08)|rgba(255,34,68,0.4)|#ff5566',warn:'rgba(255,170,0,0.08)|rgba(255,170,0,0.3)|#ffaa00'}[t]||'rgba(26,111,255,0.1)|rgba(26,111,255,0.3)|#4d9fff';const[bg,bc,col]=c.split('|');el.style.cssText='background:'+bg+';border-color:'+bc+';color:'+col;el.textContent=m;}

async function placeFreeOrder(){
  const btn=document.getElementById('pay-btn');btn.disabled=true;btn.textContent='CREATING ORDER...';setStat('Creating free order...','info');
  try{const r=await fetch('/checkout/confirm-free',{method:'POST',headers:{'Content-Type':'application/json'}});const d=await r.json();
  if(d.success){setStat('Order '+d.orderId+' created! Redirecting...','success');btn.textContent='ORDER PLACED';setTimeout(()=>window.location.href='/orders/'+d.orderId,1500);}
  else{setStat(d.error||'Failed','error');btn.disabled=false;btn.textContent='PLACE ORDER →';}}catch(e){setStat('Network error','error');btn.disabled=false;btn.textContent='PLACE ORDER →';}
}

async function initiatePayment(){
  const btn=document.getElementById('pay-btn');btn.disabled=true;btn.textContent='PREPARING...';
  try{
    let p=window.solana?.isPhantom?window.solana:window.backpack||(window.solflare?.isSolflare?window.solflare:null);
    if(!p){setStat('No Solana wallet detected. Install Phantom, Backpack, or Solflare.','error');btn.disabled=false;btn.textContent='PAY NOW';return;}
    if(!p.isConnected){try{await p.connect();}catch(e){setStat('Wallet connection rejected.','error');btn.disabled=false;btn.textContent='PAY NOW';return;}}
    if(!AGENCY_WALLET){setStat('Agency wallet not configured.','error');btn.disabled=false;btn.textContent='PAY NOW';return;}
    if(SOL_PRICE<=0){setStat('Cannot fetch SOL price. Please refresh.','error');btn.disabled=false;btn.textContent='PAY NOW';return;}
    const lamports=Math.round((TOTAL_USD/SOL_PRICE)*1e9);
    if(!lamports||lamports<1){setStat('Invalid amount.','error');btn.disabled=false;btn.textContent='PAY NOW';return;}
    const rpc=QUICKNODE_RPC||'https://api.mainnet-beta.solana.com';
    setStat('Fetching blockhash...','info');btn.textContent='BUILDING TX...';
    const bh=await(await fetch(rpc,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({jsonrpc:'2.0',id:1,method:'getLatestBlockhash',params:[{commitment:'finalized'}]})})).json();
    if(bh.error)throw new Error('RPC: '+bh.error.message);
    const{Transaction,SystemProgram,PublicKey}=window.solanaWeb3;
    const tx=new Transaction({recentBlockhash:bh.result.value.blockhash,feePayer:new PublicKey(p.publicKey.toString())}).add(SystemProgram.transfer({fromPubkey:new PublicKey(p.publicKey.toString()),toPubkey:new PublicKey(AGENCY_WALLET),lamports}));
    setStat('Approve in your wallet...','info');btn.textContent='WAITING FOR APPROVAL...';
    let signed;try{signed=await p.signTransaction(tx);}catch(e){setStat(e.message?.toLowerCase().includes('reject')||e.code===4001?'Transaction rejected.':'Signing error: '+e.message,'error');btn.disabled=false;btn.textContent='PAY NOW';return;}
    setStat('Sending to Solana...','info');btn.textContent='SENDING...';
    const raw=btoa(String.fromCharCode(...signed.serialize()));
    const sr=await(await fetch(rpc,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({jsonrpc:'2.0',id:1,method:'sendTransaction',params:[raw,{encoding:'base64',preflightCommitment:'confirmed'}]})})).json();
    if(sr.error)throw new Error('Send failed: '+sr.error.message);
    const txHash=sr.result;
    setStat('TX sent. Confirming...','info');btn.textContent='CONFIRMING...';
    let confirmed=false;
    if(QUICKNODE_WSS)confirmed=await wssConfirm(QUICKNODE_WSS,txHash);
    if(!confirmed){for(let i=0;i<25&&!confirmed;i++){await new Promise(r=>setTimeout(r,2500));try{const st=await(await fetch(rpc,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({jsonrpc:'2.0',id:1,method:'getSignatureStatuses',params:[[txHash]]})})).json();const sig=st?.result?.value?.[0];if(sig&&(sig.confirmationStatus==='confirmed'||sig.confirmationStatus==='finalized'))confirmed=true;}catch(e){}}}
    if(confirmed)setStat('Payment confirmed!','success');else setStat('TX submitted. Processing once confirmed. TX: '+txHash,'warn');
    btn.textContent='CREATING ORDER...';
    const od=await(await fetch('/checkout/confirm',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({txHash,totalSOL:SOL_TOTAL})})).json();
    if(od.success){setStat('Order '+od.orderId+' placed!','success');btn.textContent='ORDER PLACED';setTimeout(()=>window.location.href='/orders/'+od.orderId,1500);}
    else{setStat('Payment sent (TX: '+txHash+') but order failed. Save TX hash and contact us.','error');btn.disabled=false;btn.textContent='RETRY';}
  }catch(err){console.error(err);setStat('Error: '+err.message,'error');const btn=document.getElementById('pay-btn');btn.disabled=false;btn.textContent='PAY NOW';}
}

function wssConfirm(url,sig){return new Promise(resolve=>{let done=false;const to=setTimeout(()=>{if(!done){done=true;try{ws.close();}catch(e){}resolve(false);}},30000);let ws;try{ws=new WebSocket(url);}catch(e){clearTimeout(to);resolve(false);return;}ws.onopen=()=>ws.send(JSON.stringify({jsonrpc:'2.0',id:1,method:'signatureSubscribe',params:[sig,{commitment:'confirmed'}]}));ws.onmessage=e=>{try{const m=JSON.parse(e.data);if(m.method==='signatureNotification'){clearTimeout(to);done=true;ws.close();resolve(m.params?.result?.value?.err===null);}}catch(e){}};ws.onerror=ws.onclose=()=>{if(!done){done=true;clearTimeout(to);resolve(false);}};});}
</script>
<script src="https://unpkg.com/@solana/web3.js@latest/lib/index.iife.min.js"></script>
<script>if(typeof solanaWeb3!=='undefined')window.solanaWeb3=solanaWeb3;</script>
<%- include('partials/footer') %>
