<%- include('partials/header') %>

<div class="content-layer pt-28 min-h-screen">
  <div class="max-w-2xl mx-auto px-6 pb-24">

    <div class="mb-10">
      <p class="font-mono text-xs tracking-[0.3em] mb-2" style="color:var(--blue-core)">FINAL STEP</p>
      <h1 class="font-display font-extrabold text-4xl">CHECKOUT</h1>
      <p class="font-mono text-xs text-slate-500 mt-2">WALLET: <span style="color:var(--blue-pale)"><%= walletAddress %></span></p>
    </div>

    <% if (!cart || cart.length === 0) { %>
      <div class="text-center py-12">
        <p class="font-mono text-slate-500 mb-6">CART IS EMPTY</p>
        <a href="/dashboard" class="btn-glow px-8 py-3 rounded-sm">BROWSE SERVICES →</a>
      </div>
    <% } else { %>

    <!-- Order summary -->
    <div class="service-card rounded-sm p-6 mb-6">
      <h3 class="font-mono text-xs tracking-widest text-slate-400 mb-4">ORDER SUMMARY</h3>
      <% cart.forEach(item => { %>
      <div class="flex justify-between items-center py-2 border-b last:border-0" style="border-color:var(--dark-border)">
        <span class="text-sm text-slate-200"><%= item.icon || '◈' %> <%= item.name %></span>
        <span class="font-mono text-sm" style="color:var(--blue-bright)"><%= item.price === 0 ? 'FREE' : '$' + item.price %></span>
      </div>
      <% }) %>
      <div class="flex justify-between items-center pt-4 mt-2">
        <span class="font-mono text-xs text-slate-400">TOTAL DUE</span>
        <div class="text-right">
          <% if (total === 0) { %>
            <div class="font-display font-bold text-2xl" style="color:#00ff88">FREE</div>
          <% } else { %>
            <div class="font-display font-bold text-2xl" style="color:var(--blue-bright)">$<%= total %></div>
            <% if (solPrice && solTotal && parseFloat(solTotal) > 0) { %>
            <div class="font-mono text-xs text-slate-400 mt-1">≈ <span id="sol-amount"><%= solTotal %></span> SOL</div>
            <% } %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Status messages -->
    <div id="payment-status" class="hidden mb-4 p-4 rounded-sm font-mono text-sm" style="border:1px solid var(--dark-border)"></div>

    <% if (total === 0) { %>
    <!-- FREE ORDER -->
    <div class="p-4 rounded-sm mb-5 font-mono text-xs" style="background:rgba(0,255,136,0.06); border:1px solid rgba(0,255,136,0.2); color:#00cc77;">
      ◈ NO PAYMENT REQUIRED — FREE TEST ORDER<br>
      ◈ ORDER CREATED INSTANTLY<br>
      ◈ DISCORD NOTIFICATION WILL FIRE
    </div>
    <button onclick="placeFreeOrder()" id="pay-btn" class="btn-glow w-full py-4 rounded-sm text-base mb-3">PLACE ORDER →</button>

    <% } else if (agencyWallet && agencyWallet !== 'YourAgencyWalletPublicKeyHere') { %>
    <!-- PAID ORDER -->
    <button onclick="initiatePayment()" id="pay-btn" class="btn-glow w-full py-4 rounded-sm text-base mb-3">
      PAY <%= (solPrice && solTotal) ? solTotal + ' SOL' : '$' + total %> NOW
    </button>

    <% } else { %>
    <div class="p-4 rounded-sm mb-3 font-mono text-xs text-yellow-400 mb-4" style="background:rgba(255,170,0,0.08); border:1px solid rgba(255,170,0,0.3)">
      ⚠ Agency wallet not configured in .env
    </div>
    <% } %>

    <a href="/cart" class="btn-outline block w-full text-center py-3 rounded-sm">← BACK TO CART</a>
    <p class="font-mono text-xs text-slate-600 text-center mt-5">Payments processed on Solana Mainnet via QuickNode RPC</p>
    <% } %>
  </div>
</div>

<script>
const QUICKNODE_RPC = '<%= quicknodeRpc || "" %>';
const QUICKNODE_WSS = '<%= quicknodeWss || "" %>';
const AGENCY_WALLET = '<%= agencyWallet || "" %>';
const TOTAL_USD = <%= total || 0 %>;
const SOL_TOTAL = '<%= solTotal || "0" %>';
const SOL_PRICE = <%= solPrice || 0 %>;

function setStatus(msg, type) {
  const el = document.getElementById('payment-status');
  if (!el) return;
  el.classList.remove('hidden');
  const cfg = { info:{bg:'rgba(26,111,255,0.1)',border:'rgba(26,111,255,0.3)',color:'#4d9fff'}, success:{bg:'rgba(0,255,136,0.08)',border:'rgba(0,255,136,0.3)',color:'#00ff88'}, error:{bg:'rgba(255,34,68,0.08)',border:'rgba(255,34,68,0.4)',color:'#ff5566'}, warn:{bg:'rgba(255,170,0,0.08)',border:'rgba(255,170,0,0.3)',color:'#ffaa00'} };
  const c = cfg[type] || cfg.info;
  el.style.background = c.bg; el.style.borderColor = c.border; el.style.color = c.color;
  el.textContent = msg;
}

async function placeFreeOrder() {
  const btn = document.getElementById('pay-btn');
  btn.disabled = true; btn.textContent = 'CREATING ORDER...';
  setStatus('Creating free order...', 'info');
  try {
    const res = await fetch('/checkout/confirm-free', { method:'POST', headers:{'Content-Type':'application/json'} });
    const data = await res.json();
    if (data.success) {
      setStatus('✓ Order ' + data.orderId + ' created! Redirecting...', 'success');
      btn.textContent = '✓ ORDER PLACED';
      setTimeout(() => window.location.href = '/orders/' + data.orderId, 1500);
    } else {
      setStatus('Error: ' + (data.error || 'Failed'), 'error');
      btn.disabled = false; btn.textContent = 'PLACE ORDER →';
    }
  } catch(e) { setStatus('Network error: ' + e.message, 'error'); btn.disabled = false; btn.textContent = 'PLACE ORDER →'; }
}

async function initiatePayment() {
  const btn = document.getElementById('pay-btn');
  btn.disabled = true; btn.textContent = 'PREPARING...';

  try {
    let provider = window.solana?.isPhantom ? window.solana : window.backpack || (window.solflare?.isSolflare ? window.solflare : null);
    if (!provider) { setStatus('No Solana wallet detected. Install Phantom, Backpack, or Solflare.', 'error'); btn.disabled=false; btn.textContent='PAY NOW'; return; }
    if (!provider.isConnected) { try { await provider.connect(); } catch(e) { setStatus('Wallet connection rejected.', 'error'); btn.disabled=false; btn.textContent='PAY NOW'; return; } }
    if (!AGENCY_WALLET) { setStatus('Agency wallet not configured.', 'error'); btn.disabled=false; btn.textContent='PAY NOW'; return; }
    if (SOL_PRICE <= 0) { setStatus('Cannot fetch SOL price. Please refresh.', 'error'); btn.disabled=false; btn.textContent='PAY NOW'; return; }

    // Full payment (not 50%)
    const fullSOL = TOTAL_USD / SOL_PRICE;
    const lamports = Math.round(fullSOL * 1_000_000_000);
    if (!lamports || lamports < 1) { setStatus('Invalid amount.', 'error'); btn.disabled=false; btn.textContent='PAY NOW'; return; }

    const rpcUrl = QUICKNODE_RPC || 'https://api.mainnet-beta.solana.com';
    setStatus('Fetching blockhash...', 'info'); btn.textContent = 'BUILDING TX...';

    const bhRes = await fetch(rpcUrl, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({jsonrpc:'2.0',id:1,method:'getLatestBlockhash',params:[{commitment:'finalized'}]}) });
    const bhData = await bhRes.json();
    if (bhData.error) throw new Error('RPC: ' + bhData.error.message);
    const { blockhash } = bhData.result.value;

    const { Transaction, SystemProgram, PublicKey } = window.solanaWeb3;
    const fromPubkey = new PublicKey(provider.publicKey.toString());
    const toPubkey = new PublicKey(AGENCY_WALLET);
    const tx = new Transaction({ recentBlockhash: blockhash, feePayer: fromPubkey }).add(SystemProgram.transfer({ fromPubkey, toPubkey, lamports }));

    setStatus('Approve in your wallet...', 'info'); btn.textContent = 'WAITING FOR APPROVAL...';
    let signedTx;
    try { signedTx = await provider.signTransaction(tx); }
    catch(e) { const rej = e.message?.toLowerCase().includes('reject') || e.code===4001; setStatus(rej ? 'Transaction rejected.' : 'Signing error: '+e.message, 'error'); btn.disabled=false; btn.textContent='PAY NOW'; return; }

    setStatus('Sending to Solana...', 'info'); btn.textContent = 'SENDING...';
    const rawB64 = btoa(String.fromCharCode(...signedTx.serialize()));
    const sendRes = await fetch(rpcUrl, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({jsonrpc:'2.0',id:1,method:'sendTransaction',params:[rawB64,{encoding:'base64',preflightCommitment:'confirmed'}]}) });
    const sendData = await sendRes.json();
    if (sendData.error) throw new Error('Send failed: ' + sendData.error.message);
    const txHash = sendData.result;

    setStatus('TX sent. Confirming...', 'info'); btn.textContent = 'CONFIRMING...';

    let confirmed = false;
    const wssUrl = QUICKNODE_WSS;
    if (wssUrl) confirmed = await confirmViaWss(wssUrl, txHash);
    if (!confirmed) {
      for (let i = 0; i < 25; i++) {
        await new Promise(r => setTimeout(r, 2500));
        try {
          const st = await fetch(rpcUrl, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({jsonrpc:'2.0',id:1,method:'getSignatureStatuses',params:[[txHash]]}) });
          const sd = await st.json();
          const sig = sd?.result?.value?.[0];
          if (sig && (sig.confirmationStatus==='confirmed'||sig.confirmationStatus==='finalized')) { confirmed=true; break; }
        } catch(e) {}
      }
    }
    if (confirmed) setStatus('✓ Payment confirmed!', 'success');
    else setStatus('TX submitted. Processing once confirmed. TX: ' + txHash, 'warn');

    btn.textContent = 'CREATING ORDER...';
    const orderRes = await fetch('/checkout/confirm', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ txHash, totalSOL: SOL_TOTAL }) });
    const orderData = await orderRes.json();
    if (orderData.success) {
      setStatus('✓ Order ' + orderData.orderId + ' placed!', 'success');
      btn.textContent = '✓ ORDER PLACED';
      setTimeout(() => window.location.href = '/orders/' + orderData.orderId, 1500);
    } else {
      setStatus('Payment sent (TX: '+txHash+') but order failed. Contact us with TX hash.', 'error');
      btn.disabled=false; btn.textContent='RETRY';
    }
  } catch(err) { console.error(err); setStatus('Error: '+err.message, 'error'); btn.disabled=false; btn.textContent='PAY NOW'; }
}

function confirmViaWss(wssUrl, txHash) {
  return new Promise(resolve => {
    let done = false;
    const timeout = setTimeout(() => { if(!done){done=true;try{ws.close();}catch(e){}resolve(false);} }, 30000);
    let ws;
    try { ws = new WebSocket(wssUrl); } catch(e) { clearTimeout(timeout); resolve(false); return; }
    ws.onopen = () => ws.send(JSON.stringify({jsonrpc:'2.0',id:1,method:'signatureSubscribe',params:[txHash,{commitment:'confirmed'}]}));
    ws.onmessage = e => { try { const m=JSON.parse(e.data); if(m.method==='signatureNotification'){clearTimeout(timeout);done=true;ws.close();resolve(m.params?.result?.value?.err===null);} } catch(e){} };
    ws.onerror = ws.onclose = () => { if(!done){done=true;clearTimeout(timeout);resolve(false);} };
  });
}
</script>
<script src="https://unpkg.com/@solana/web3.js@latest/lib/index.iife.min.js"></script>
<script>if(typeof solanaWeb3!=='undefined')window.solanaWeb3=solanaWeb3;</script>
<%- include('partials/footer') %>
