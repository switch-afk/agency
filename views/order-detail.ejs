<%- include('partials/header') %>
<style>
.chat-bubble{max-width:78%;padding:10px 14px;border-radius:4px;font-size:0.875rem;line-height:1.5;word-break:break-word;}
.chat-client{background:rgba(26,111,255,0.15);border:1px solid rgba(26,111,255,0.25);margin-left:auto;}
.chat-developer{background:rgba(0,200,100,0.1);border:1px solid rgba(0,200,100,0.25);}
.chat-admin{background:rgba(255,170,0,0.1);border:1px solid rgba(255,170,0,0.25);}
.ci{background:var(--dark-bg);border:1px solid var(--dark-border);color:#e8f0ff;padding:10px 14px;font-family:'DM Sans',sans-serif;font-size:0.875rem;outline:none;transition:border-color 0.2s;width:100%;}
.ci:focus{border-color:var(--blue-core);}
.ci::placeholder{color:#3a4a6a;}
.dz{border:2px dashed var(--dark-border);border-radius:4px;padding:20px;text-align:center;cursor:pointer;transition:border-color 0.2s;}
.dz:hover,.dz.over{border-color:var(--blue-core);}
</style>

<div class="content-layer pt-28 min-h-screen">
<div class="max-w-5xl mx-auto px-6 pb-24">

  <div class="flex items-center gap-2 mb-8" style="font-family:monospace;font-size:0.7rem;color:#4a5a7a;">
    <a href="/dashboard" class="hover:text-white">DASHBOARD</a><span>&rsaquo;</span>
    <span style="color:var(--blue-pale);"><%= order.id %></span>
  </div>

  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
      <p style="font-family:monospace;font-size:0.65rem;letter-spacing:0.3em;color:var(--blue-core);margin-bottom:4px;">ORDER</p>
      <h1 class="font-display font-extrabold text-3xl"><%= order.id %></h1>
      <p style="font-family:monospace;font-size:0.65rem;color:#4a5a7a;margin-top:4px;"><%= new Date(order.createdAt).toLocaleString('en-US',{dateStyle:'medium',timeStyle:'short'}) %></p>
    </div>
    <div class="flex items-center gap-3 flex-wrap">
      <span class="status-badge status-<%= order.status %>"><%= order.status.replace(/_/g,' ') %></span>
      <% if (order.txHash) { %>
        <a href="https://solscan.io/tx/<%= order.txHash %>" target="_blank" class="font-mono text-xs px-3 py-1 rounded-sm" style="border:1px solid rgba(26,111,255,0.3);color:var(--blue-bright);">VIEW TX</a>
      <% } %>
    </div>
  </div>

  <div class="grid md:grid-cols-3 gap-6">
  <div class="md:col-span-2 flex flex-col gap-5">

    <!-- Services -->
    <div class="service-card rounded-sm p-5">
      <h3 class="font-mono text-xs tracking-widest text-slate-400 mb-4">SERVICES ORDERED</h3>
      <% order.items.forEach(function(item){ %>
      <div class="flex justify-between items-center py-2 border-b last:border-0" style="border-color:var(--dark-border)">
        <span class="text-sm"><%= item.icon||'' %> <%= item.name %></span>
        <span class="font-mono text-sm" style="color:var(--blue-bright)"><%= item.price===0?'FREE':'$'+item.price %></span>
      </div>
      <% }); %>
      <div class="flex justify-between pt-3 mt-1">
        <span class="font-mono text-xs text-slate-500">TOTAL PAID</span>
        <span class="font-display font-bold" style="color:var(--blue-bright)"><%= order.totalUSD===0?'FREE':'$'+order.totalUSD %></span>
      </div>
    </div>

    <!-- Project Details (client) -->
    <% if (isClient) { %>
    <div class="service-card rounded-sm p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-mono text-xs tracking-widest text-slate-400">PROJECT DETAILS</h3>
        <% if (order.projectDetails) { %>
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs px-2 py-1 rounded-sm" style="background:rgba(0,255,136,0.1);color:#00ff88;border:1px solid rgba(0,255,136,0.2);">SUBMITTED</span>
            <button onclick="toggleEdit()" class="font-mono text-xs text-slate-400 hover:text-white">EDIT</button>
          </div>
        <% } %>
      </div>
      <% if (order.projectDetails) { %>
      <div id="det-view" class="flex flex-col gap-2 text-sm mb-3">
        <div><span class="font-mono text-xs text-slate-500">PROJECT: </span><span class="text-white font-semibold"><%= order.projectDetails.projectName %></span></div>
        <div><span class="font-mono text-xs text-slate-500">DESC: </span><span class="text-slate-300 leading-relaxed"><%= order.projectDetails.description %></span></div>
      </div>
      <% } %>
      <form id="det-form" class="<%= order.projectDetails ? 'hidden' : '' %> flex flex-col gap-4" onsubmit="submitDetails(event)">
        <div>
          <label class="font-mono text-xs text-slate-500 block mb-2">PROJECT NAME *</label>
          <input name="projectName" required value="<%= order.projectDetails ? order.projectDetails.projectName : '' %>" placeholder="Your project name..." class="ci rounded-sm" />
        </div>
        <div>
          <label class="font-mono text-xs text-slate-500 block mb-2">DESCRIPTION *</label>
          <textarea name="description" required rows="4" class="ci rounded-sm" style="resize:none;" placeholder="Describe what you want built..."><%= order.projectDetails ? order.projectDetails.description : '' %></textarea>
        </div>
        <div id="det-status" class="hidden font-mono text-xs p-3 rounded-sm"></div>
        <button type="submit" id="det-btn" class="btn-glow py-3 rounded-sm">SUBMIT PROJECT DETAILS</button>
      </form>
    </div>
    <% } %>

    <!-- Project Details (admin/dev read-only) -->
    <% if ((isAdmin||isDev) && order.projectDetails) { %>
    <div class="service-card rounded-sm p-5">
      <h3 class="font-mono text-xs tracking-widest text-slate-400 mb-4">PROJECT DETAILS</h3>
      <div class="flex flex-col gap-2 text-sm">
        <div><span class="font-mono text-xs text-slate-500">PROJECT: </span><span class="text-white font-semibold"><%= order.projectDetails.projectName %></span></div>
        <div><span class="font-mono text-xs text-slate-500">DESC: </span><span class="text-slate-300"><%= order.projectDetails.description %></span></div>
      </div>
    </div>
    <% } %>

    <!-- Attachments + Upload (always visible to client/admin/dev) -->
    <div class="service-card rounded-sm p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-mono text-xs tracking-widest text-slate-400">
          ATTACHMENTS<% if (attachments && attachments.length > 0) { %> (<%= attachments.length %>)<% } %>
        </h3>
        <% if (isAdmin||isDev) { %>
          <a href="/orders/<%= order.id %>/attachments/zip" class="font-mono text-xs px-3 py-1 rounded-sm" style="border:1px solid var(--dark-border);color:var(--blue-bright);">ZIP ALL</a>
        <% } %>
      </div>

      <!-- File list -->
      <% if (attachments && attachments.length > 0) { %>
      <div class="flex flex-col gap-2 mb-4" id="att-list">
        <% attachments.forEach(function(att){ %>
        <div class="flex items-center gap-3 p-3 rounded-sm" style="background:rgba(26,111,255,0.04);border:1px solid var(--dark-border);">
          <div class="flex-1 min-w-0">
            <div class="font-mono text-xs text-slate-200 truncate"><%= att.name %></div>
            <div class="font-mono text-slate-600 mt-0.5" style="font-size:0.6rem;"><%= att.sizeStr %></div>
          </div>
          <% if (att.isImg) { %>
            <a href="/orders/<%= order.id %>/img/<%= att.filename %>" target="_blank" class="font-mono text-xs text-slate-400 hover:text-white flex-shrink-0">VIEW</a>
            <span class="text-slate-600 text-xs">|</span>
          <% } %>
          <a href="/orders/<%= order.id %>/img/<%= att.filename %>" target="_blank" download="<%= att.name %>" class="font-mono text-xs flex-shrink-0" style="color:var(--blue-bright);">DOWNLOAD</a>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="font-mono text-xs text-slate-600 mb-4">No files attached yet.</div>
      <% } %>

      <!-- Multi-file upload (client only) -->
      <% if (isClient) { %>
      <div>
        <div class="dz" id="att-dz"
          onclick="document.getElementById('att-fi').click()"
          ondragover="event.preventDefault();this.classList.add('over')"
          ondragleave="this.classList.remove('over')"
          ondrop="attDrop(event)">
          <div class="font-mono text-xs text-slate-500">DRAG AND DROP OR CLICK TO ATTACH FILES</div>
          <div class="font-mono text-slate-600 mt-1" style="font-size:0.6rem;">Any file type, max 20MB each, multiple files supported</div>
        </div>
        <input type="file" id="att-fi" multiple class="hidden" onchange="handleAttFiles(this.files)" />
        <div id="att-queue" class="hidden flex flex-col gap-1 mt-2"></div>
        <div id="att-status" class="hidden font-mono text-xs p-2 rounded-sm mt-2"></div>
        <button id="att-btn" onclick="uploadAttachments()" class="hidden btn-glow w-full py-2 rounded-sm text-xs mt-2">UPLOAD FILES</button>
      </div>
      <% } %>
    </div>

    <!-- Chat (NO attach button) -->
    <div class="service-card rounded-sm flex flex-col" style="height:520px;">
      <div class="p-4 border-b flex items-center justify-between" style="border-color:var(--dark-border);">
        <h3 class="font-mono text-xs tracking-widest text-slate-400">PROJECT CHAT</h3>
        <% if (order.developerName) { %>
          <span class="font-mono text-xs flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background:#00ff88;box-shadow:0 0 6px #00ff88;"></span>
            <%= order.developerName %>
          </span>
        <% } else { %>
          <span class="font-mono text-xs text-slate-600">AWAITING DEVELOPER</span>
        <% } %>
      </div>

      <div id="chat-box" class="flex-1 overflow-y-auto p-4 flex flex-col gap-3">
        <% if (!messages || messages.length === 0) { %>
          <div id="chat-empty" class="text-center font-mono text-xs text-slate-600 mt-10">NO MESSAGES YET</div>
        <% } else { %>
          <% messages.forEach(function(msg){ %>
            <%
              var isMe = (msg.senderWallet === walletAddress);
              var rc = 'chat-' + (msg.role || 'client');
              var align = isMe ? 'items-end' : 'items-start';
              var nr = isMe ? 'flex-row-reverse' : '';
              var t = new Date(msg.at).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
              var hasContent = msg.text && msg.text.length > 0;
            %>
            <% if (hasContent) { %>
            <div class="flex flex-col gap-1 <%= align %>">
              <div class="flex items-center gap-2 <%= nr %>" style="font-size:0.7rem;">
                <span style="color:#6a7a9a;font-family:monospace;"><%= msg.senderName %></span>
                <span style="color:#2a3a5a;font-family:monospace;font-size:0.55rem;"><%= t %></span>
              </div>
              <div class="<%= rc %> chat-bubble"><%= msg.text %></div>
            </div>
            <% } %>
          <% }); %>
        <% } %>
      </div>

      <div class="p-3 flex gap-2 items-end" style="border-top:1px solid var(--dark-border);">
        <textarea id="chat-in" rows="1" placeholder="Type a message..."
          class="ci rounded-sm flex-1" style="resize:none;min-height:40px;max-height:120px;"
          oninput="autoResize(this)"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg();}"></textarea>
        <button onclick="sendMsg()" class="btn-glow px-4 py-2 rounded-sm flex-shrink-0">SEND</button>
      </div>
    </div>

  </div>

  <!-- Sidebar -->
  <div class="flex flex-col gap-4">
    <% if (order.developerName) { %>
    <div class="service-card rounded-sm p-4">
      <div class="font-mono text-xs text-slate-500 mb-2">DEVELOPER</div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full" style="background:#00ff88;box-shadow:0 0 6px #00ff88;"></span>
        <span class="font-display font-semibold"><%= order.developerName %></span>
      </div>
    </div>
    <% } %>

    <div class="service-card rounded-sm p-4">
      <div class="font-mono text-xs text-slate-500 mb-4">PROGRESS</div>
      <%
        var stages = [
          {k:'pending_payment',l:'Order Placed'},
          {k:'paid',l:'Payment Confirmed'},
          {k:'in_progress',l:'In Development'},
          {k:'review',l:'Under Review'},
          {k:'delivered',l:'Delivered'},
          {k:'completed',l:'Completed'}
        ];
        var ci = -1;
        for (var si = 0; si < stages.length; si++) {
          if (stages[si].k === order.status) { ci = si; break; }
        }
      %>
      <div class="flex flex-col gap-3">
        <% for (var si = 0; si < stages.length; si++) { %>
        <div class="flex items-center gap-3">
          <div class="w-3 h-3 rounded-full flex-shrink-0" style="background:<%= order.status==='cancelled'?'#ff2244':(si<=ci?'var(--blue-core)':'var(--dark-border)') %>;box-shadow:<%= (si<=ci&&order.status!=='cancelled')?'0 0 7px rgba(26,111,255,0.5)':'none' %>;"></div>
          <span class="text-xs <%= (si<=ci&&order.status!=='cancelled')?'text-white':'text-slate-600' %>"><%= stages[si].l %></span>
        </div>
        <% } %>
      </div>
    </div>

    <div class="service-card rounded-sm p-4">
      <div class="font-mono text-xs text-slate-500 mb-3">TIMELINE</div>
      <div class="flex flex-col gap-3" style="max-height:300px;overflow-y:auto;">
        <% var tl = order.timeline.slice().reverse(); %>
        <% for (var ti = 0; ti < tl.length; ti++) { %>
        <% var ev = tl[ti]; %>
        <div class="flex items-start gap-2">
          <div class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0" style="background:var(--blue-core);"></div>
          <div>
            <div class="text-xs font-semibold text-white"><%= ev.label %></div>
            <% if(ev.note){ %><div class="text-xs text-slate-400 mt-0.5"><%= ev.note %></div><% } %>
            <div class="font-mono text-slate-600 mt-0.5" style="font-size:0.6rem;"><%= new Date(ev.at).toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  </div>
</div>
</div>

<script>
var ORDER_ID = '<%= order.id %>';
var MY_WALLET = '<%= walletAddress %>';
var lastId = <%= (messages && messages.length > 0) ? messages[messages.length-1].id : 0 %>;
var attFiles = [];

function scrollChat() {
  var b = document.getElementById('chat-box');
  if (b) b.scrollTop = b.scrollHeight;
}
scrollChat();

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function escapeHtml(s) {
  return String(s).split('&').join('&amp;').split('<').join('&lt;').split('>').join('&gt;');
}

// ─── CHAT (text only) ─────────────────────────────────────────
function appendMsg(msg) {
  if (!msg.text || msg.text.length === 0) return;
  var c = document.getElementById('chat-box');
  var emp = document.getElementById('chat-empty');
  if (emp) emp.remove();
  lastId = msg.id;
  var isMe = (msg.senderWallet === MY_WALLET);
  var rc = 'chat-' + (msg.role || 'client');
  var time = new Date(msg.at).toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
  var align = isMe ? 'items-end' : 'items-start';
  var nr = isMe ? 'flex-row-reverse' : '';
  var div = document.createElement('div');
  div.className = 'flex flex-col gap-1 ' + align;
  div.innerHTML = '<div class="flex items-center gap-2 ' + nr + '" style="font-size:0.7rem;">'
    + '<span style="color:#6a7a9a;font-family:monospace;">' + escapeHtml(msg.senderName) + '</span>'
    + '<span style="color:#2a3a5a;font-family:monospace;font-size:0.55rem;">' + time + '</span>'
    + '</div><div class="' + rc + ' chat-bubble">' + escapeHtml(msg.text) + '</div>';
  c.appendChild(div);
  scrollChat();
}

async function sendMsg() {
  var inp = document.getElementById('chat-in');
  var text = inp.value.trim();
  if (!text) return;
  inp.value = '';
  inp.style.height = 'auto';
  try {
    var r = await fetch('/orders/' + ORDER_ID + '/chat', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({text: text})
    });
    var d = await r.json();
    if (d.success) appendMsg(d.message);
    else showToast(d.error || 'Failed to send');
  } catch(e) { showToast('Network error'); }
}

setInterval(async function() {
  try {
    var r = await fetch('/orders/' + ORDER_ID + '/chat?since=' + lastId);
    var d = await r.json();
    if (d.success && d.messages && d.messages.length > 0) {
      for (var i = 0; i < d.messages.length; i++) appendMsg(d.messages[i]);
    }
  } catch(e) {}
}, 4000);

// ─── PROJECT DETAILS ──────────────────────────────────────────
function toggleEdit() {
  var f = document.getElementById('det-form');
  var v = document.getElementById('det-view');
  if (f) f.classList.toggle('hidden');
  if (v) v.classList.toggle('hidden');
}

async function submitDetails(e) {
  e.preventDefault();
  var form = e.target;
  var stat = document.getElementById('det-status');
  var btn = document.getElementById('det-btn');
  btn.disabled = true;
  btn.textContent = 'SUBMITTING...';
  try {
    var r = await fetch('/orders/' + ORDER_ID + '/project-details', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        projectName: form.projectName.value.trim(),
        description: form.description.value.trim()
      })
    });
    var d = await r.json();
    if (!d.success) {
      showStat(stat, d.error || 'Failed', 'error');
      btn.disabled = false;
      btn.textContent = 'SUBMIT PROJECT DETAILS';
      return;
    }
    showStat(stat, 'Saved!', 'ok');
    btn.textContent = 'SUBMITTED';
    setTimeout(function() { location.reload(); }, 1000);
  } catch(err) {
    showStat(stat, 'Network error', 'error');
    btn.disabled = false;
    btn.textContent = 'SUBMIT PROJECT DETAILS';
  }
}

// ─── MULTI-FILE ATTACHMENT UPLOAD ─────────────────────────────
function handleAttFiles(files) {
  attFiles = Array.from(files);
  renderAttQueue();
}

function attDrop(e) {
  e.preventDefault();
  document.getElementById('att-dz').classList.remove('over');
  attFiles = Array.from(e.dataTransfer.files);
  renderAttQueue();
}

function renderAttQueue() {
  var q = document.getElementById('att-queue');
  var btn = document.getElementById('att-btn');
  if (!attFiles.length) { q.classList.add('hidden'); btn.classList.add('hidden'); return; }
  q.classList.remove('hidden');
  btn.classList.remove('hidden');
  q.innerHTML = '';
  attFiles.forEach(function(f, i) {
    var row = document.createElement('div');
    row.className = 'flex items-center gap-2 font-mono text-xs text-slate-400 p-2 rounded-sm';
    row.style.cssText = 'background:rgba(26,111,255,0.04);border:1px solid var(--dark-border);';
    row.innerHTML = '<span class="flex-1 truncate">' + escapeHtml(f.name) + '</span>'
      + '<span style="color:#4a5a7a;">' + (f.size < 1048576 ? (f.size/1024).toFixed(1)+'KB' : (f.size/1048576).toFixed(1)+'MB') + '</span>'
      + '<button onclick="removeAttFile('+i+')" style="color:#ff5566;background:none;border:none;cursor:pointer;font-size:0.75rem;">x</button>';
    q.appendChild(row);
  });
}

function removeAttFile(idx) {
  attFiles.splice(idx, 1);
  document.getElementById('att-fi').value = '';
  renderAttQueue();
}

async function uploadAttachments() {
  if (!attFiles.length) return;
  var btn = document.getElementById('att-btn');
  var stat = document.getElementById('att-status');
  btn.disabled = true;
  btn.textContent = 'UPLOADING...';
  var fd = new FormData();
  attFiles.forEach(function(f) { fd.append('files', f); });
  try {
    var r = await fetch('/orders/' + ORDER_ID + '/upload-doc', {method:'POST', body:fd});
    var d = await r.json();
    if (d.success) {
      showStat(stat, 'Files uploaded successfully!', 'ok');
      attFiles = [];
      document.getElementById('att-fi').value = '';
      renderAttQueue();
      setTimeout(function() { location.reload(); }, 1000);
    } else {
      showStat(stat, d.error || 'Upload failed', 'error');
      btn.disabled = false;
      btn.textContent = 'UPLOAD FILES';
    }
  } catch(e) {
    showStat(stat, 'Network error', 'error');
    btn.disabled = false;
    btn.textContent = 'UPLOAD FILES';
  }
}

function showStat(el, msg, type) {
  el.classList.remove('hidden');
  var ok = 'background:rgba(0,255,136,0.08);color:#00ff88;border:1px solid rgba(0,255,136,0.2);';
  var err = 'background:rgba(255,34,68,0.08);color:#ff5566;border:1px solid rgba(255,34,68,0.3);';
  el.style.cssText = (type === 'ok' ? ok : err);
  el.textContent = msg;
}
</script>

<%- include('partials/footer') %>
