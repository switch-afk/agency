<%- include('partials/header') %>
<div class="layer pt-24 sm:pt-28 min-h-screen">
<div class="max-w-4xl mx-auto px-4 sm:px-6 pb-16 sm:pb-24">
  <div class="mb-8 sm:mb-10">
    <p class="font-mono text-xs tracking-[0.3em] mb-2 text-brand-core">ORDER SUMMARY</p>
    <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-white">YOUR CART</h1>
    <p class="font-mono text-xs text-slate-500 mt-2 break-all">WALLET: <span class="text-brand-pale"><%= walletAddress %></span></p>
  </div>

  <% if (!cart || cart.length === 0) { %>
    <div class="text-center py-20">
      <p class="font-mono text-slate-500 mb-6">YOUR CART IS EMPTY</p>
      <a href="/dashboard" class="inline-block font-mono text-xs px-8 py-3 rounded-sm text-white" style="background:#1a6fff">BROWSE SERVICES →</a>
    </div>
  <% } else { %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
    <div class="md:col-span-2 flex flex-col gap-3">
      <% cart.forEach(item => { %>
      <div class="card rounded-sm p-4 sm:p-5 flex items-center justify-between gap-3">
        <div class="flex items-center gap-3 flex-1 min-w-0">
          <span class="text-xl sm:text-2xl flex-shrink-0"><%= item.icon||'◈' %></span>
          <div class="min-w-0">
            <h3 class="font-display font-semibold text-sm sm:text-base text-white truncate"><%= item.name %></h3>
            <p class="font-mono text-xs text-slate-500 mt-0.5">SOLANA ECOSYSTEM SERVICE</p>
          </div>
        </div>
        <div class="flex items-center gap-3 flex-shrink-0">
          <span class="font-display font-bold text-lg sm:text-xl text-brand-bright">$<%= item.price %></span>
          <button onclick="removeLine('<%= item.id %>')" class="font-mono text-xs px-3 py-1.5 rounded-sm border text-red-400 hover:text-red-300 hover:border-red-500 transition-all" style="border-color:#4a1111">✕</button>
        </div>
      </div>
      <% }) %>
    </div>

    <div class="md:col-span-1">
      <div class="card rounded-sm p-5 sm:p-6 md:sticky md:top-24">
        <h3 class="font-display font-bold text-lg text-white mb-5">ORDER TOTAL</h3>
        <div class="flex flex-col gap-2 mb-4">
          <% cart.forEach(item => { %>
          <div class="flex justify-between items-center">
            <span class="text-xs text-slate-400 truncate max-w-[60%]"><%= item.name %></span>
            <span class="font-mono text-sm text-slate-300">$<%= item.price %></span>
          </div>
          <% }) %>
        </div>
        <div class="border-t border-dark-border pt-4 mb-2">
          <div class="flex justify-between items-center">
            <span class="font-mono text-xs text-slate-400">TOTAL (USD)</span>
            <span class="font-display font-bold text-2xl text-brand-bright">$<%= total %></span>
          </div>
        </div>
        <% if (solPrice && solTotal && parseFloat(solTotal) > 0) { %>
        <div class="flex justify-between items-center mb-5">
          <span class="font-mono text-xs text-slate-500">≈ SOL</span>
          <span class="font-mono text-sm text-slate-300"><%= solTotal %> SOL</span>
        </div>
        <% } else { %><div class="mb-5"></div><% } %>
        <div class="p-3 rounded-sm mb-4 font-mono text-xs text-slate-500 border border-dark-border" style="background:rgba(26,111,255,0.04)">
          ◈ FULL PAYMENT ON ORDER<br>◈ SOL ON SOLANA MAINNET
        </div>
        <a href="/checkout" class="block w-full text-center font-mono text-xs py-3 rounded-sm text-white mb-3" style="background:#1a6fff">PROCEED TO PAYMENT →</a>
        <a href="/dashboard" class="block w-full text-center font-mono text-xs py-3 rounded-sm border border-brand-core text-brand-pale hover:bg-brand-core hover:text-white transition-all">← ADD MORE SERVICES</a>
      </div>
    </div>
  </div>
  <% } %>
</div>
</div>
<script>async function removeLine(id){await fetch('/cart/remove',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({serviceId:id})});window.location.reload();}</script>
<%- include('partials/footer') %>
